@model YoutubeMusicPlayer.Application.DTOs.PlaylistDto
@{
    ViewData["Title"] = Model.Title;
}

<div class="playlist-details-container animate-fade-in">
    <!-- HEADER -->
    <div class="playlist-hero mb-5">
        <div class="playlist-hero-bg" style="background-image: url('@(string.IsNullOrEmpty(Model.CoverImageUrl) ? "https://ui-avatars.com/api/?name=" + Model.Title + "&background=6C5CE7&color=fff&size=512" : Model.CoverImageUrl)')"></div>
        <div class="playlist-hero-content d-flex align-items-end p-4 p-md-5">
            <div class="playlist-thumb shadow-2xl me-4 overflow-hidden rounded-4">
                @if (string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <div class="card-thumb-placeholder" style="font-size: 6rem;">
                        <i class="fa-solid fa-music"></i>
                    </div>
                }
                else
                {
                    <img src="@Model.CoverImageUrl" alt="@Model.Title" class="w-100 h-100 object-fit-cover">
                }
            </div>
            <div class="playlist-info">
                <span class="badge bg-white bg-opacity-10 text-white px-3 py-2 rounded-pill small fw-bold tracking-wider uppercase mb-3">PLAYLIST</span>
                <h1 class="display-2 fw-black mb-1">@Model.Title</h1>
                <p class="text-dim mb-3">@Model.Description</p>
                <div class="d-flex align-items-center gap-3 text-white-50 small">
                    <span class="fw-bold text-main">@((User.Identity?.Name) ?? "User")</span>
                    <span>•</span>
                    <span>@Model.Songs.Count() bài hát</span>
                    <span>•</span>
                    <span>@{
                        var totalSeconds = Model.TotalDurationSeconds;
                        var hours = totalSeconds / 3600;
                        var minutes = (totalSeconds % 3600) / 60;
                        var seconds = totalSeconds % 60;
                        
                        if (hours > 0) {
                            @($"{hours} giờ {minutes} phút {seconds} giây")
                        } else {
                            @($"{minutes} phút {seconds} giây")
                        }
                    }</span>
                </div>
                <div class="mt-4 d-flex align-items-center gap-3">
                    <button class="btn btn-accent rounded-circle p-3 shadow-lg" style="width: 56px; height: 56px;" onclick="playPlaylist(@Model.PlaylistId)" title="Phát tất cả">
                        <i class="fa-solid fa-play fs-4 ps-1"></i>
                    </button>
                    <button class="btn btn-white bg-white text-dark rounded-circle p-3 shadow-lg d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;" onclick="playPlaylistShuffled(@Model.PlaylistId)" title="Phát ngẫu nhiên">
                        <i class="fa-solid fa-shuffle fs-5"></i>
                    </button>
                    <a asp-action="Edit" asp-route-id="@Model.PlaylistId" class="btn btn-outline-light border-opacity-25 rounded-circle p-3" style="width: 50px; height: 50px;" title="Chỉnh sửa">
                        <i class="fa-solid fa-pen"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- SEARCH & ACTIONS -->
    <div class="glass-card mb-4 p-3 d-flex justify-content-between align-items-center gap-3">
        <div class="search-input-wrapper flex-grow-1" style="max-width: 400px;">
            <i class="fa-solid fa-magnifying-glass text-dim me-2"></i>
            <input type="text" id="playlistSearch" class="bg-transparent border-0 text-white w-100 outline-none" placeholder="Tìm bài hát trong playlist..." onkeyup="filterPlaylist()">
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-light border-opacity-10 rounded-pill btn-sm h-100" onclick="exportPlaylist()">
                <i class="fa-solid fa-share-nodes me-1"></i> Chia sẻ
            </button>
        </div>
    </div>

    <!-- SONGS LIST -->
    <div class="glass-card overflow-hidden">
        <table class="modern-table">
            <thead>
                <tr>
                    <th class="ps-4" style="width: 50px;"></th>
                    <th style="width: 40px;">#</th>
                    <th>Tiêu đề bài hát</th>
                    <th class="d-none d-md-table-cell">Thời lượng</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody id="playlistSongsTableBody" data-playlist-id="@Model.PlaylistId">
                @{ int i = 1; }
                @foreach (var s in Model.Songs)
                {
                    <tr class="song-row" data-song-id="@s.SongId" onclick="playTrackInContext(@Json.Serialize(Model.Songs), @(i - 1))">
                        <td class="ps-4 text-dim">
                            <i class="fa-solid fa-grip-vertical drag-handle cursor-move opacity-25 hover-opacity-100"></i>
                        </td>
                        <td class="text-dim fw-bold"><span class="row-index">@i</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@s.ThumbnailUrl" class="rounded me-3" style="width: 44px; height: 44px; object-fit: cover;">
                                <div>
                                    <div class="fw-bold text-main">@s.Title</div>
                                    <div class="text-dim extra-small">YouTube Player</div>
                                </div>
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell text-dim small">@(s.Duration.HasValue ? TimeSpan.FromSeconds(s.Duration.Value).ToString(@"mm\:ss") : "--:--")</td>
                        <td class="text-end pe-4">
                            <div class="d-flex align-items-center justify-content-end gap-2 action-group">
                                <button class="btn btn-icon btn-like @(s.IsLiked ? "liked" : "")" onclick="event.stopPropagation(); toggleLike(@s.SongId, this)">
                                    <i class="fa-solid fa-heart"></i>
                                </button>
                                <button class="btn-icon" title="Thêm vào Playlist" onclick="event.stopPropagation(); showAddToPlaylistModal('@s.YoutubeVideoId')">
                                    <i class="fa-solid fa-folder-plus text-accent"></i>
                                </button>
                                <a href="javascript:void(0)" 
                                   onclick="handlePremiumDownload('/Subscription/Download?youtubeId=@s.YoutubeVideoId&title=@Uri.EscapeDataString(s.Title)')"
                                   class="btn btn-icon text-dim hover-text-accent" title="Tải xuống">
                                    <i class="fa-solid fa-download"></i>
                                </a>
                                <button type="button" class="btn btn-icon text-danger hover-bg-danger bg-opacity-10" 
                                        onclick="removeSong(event, @Model.PlaylistId, @s.SongId, this)" title="Gỡ khỏi Playlist">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    i++;
                }

                @if (!Model.Songs.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-dim">
                            <i class="fa-solid fa-music display-4 mb-3 opacity-10"></i>
                            <p>Playlist này chưa có bài hát nào.<br/>Nhấn vào các bài gợi ý để thêm vào nhé!</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<style>
    .playlist-details-container { padding-bottom: 50px; }
    
    .playlist-hero {
        position: relative;
        height: 420px;
        border-radius: 24px;
        overflow: hidden;
        margin-top: -16px; 
    }
    
    .playlist-hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        filter: blur(80px) brightness(0.4);
        transform: scale(1.2);
    }
    
    .playlist-hero-content {
        position: relative;
        height: 100%;
        background: linear-gradient(to top, rgba(15, 15, 15, 0.95) 0%, transparent 100%);
        z-index: 1;
    }
    
    .playlist-thumb img {
        width: 280px;
        height: 280px;
        object-fit: cover;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .song-row {
        cursor: pointer;
        transition: 0.2s;
    }
    
    .song-row:hover {
        background: rgba(255, 255, 255, 0.03);
    }
    
    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text-dim);
        border: none;
        background: transparent;
        transition: 0.2s;
    }
    
    .btn-icon:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }
    
    .btn-like.liked {
        color: #ff4757;
    }
    
    .btn-like:hover {
        color: #ff4757;
    }
    
    .action-group {
        opacity: 0;
        transition: 0.2s;
    }
    
    .song-row:hover .action-group {
        opacity: 1;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .sortable-ghost {
        opacity: 0.4;
        background: var(--accent-color) !important;
    }

    .cursor-move { cursor: move; }
    .outline-none { outline: none; }

    .mini-song-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 12px;
        transition: 0.3s;
    }
    .mini-song-card:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }
</style>

<script>
    function filterPlaylist() {
        const input = document.getElementById('playlistSearch');
        const filter = input.value.toLowerCase();
        const rows = document.querySelectorAll('#playlistSongsTableBody .song-row');

        rows.forEach(row => {
            const title = row.querySelector('.fw-bold.text-main').textContent.toLowerCase();
            if (title.includes(filter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    function gracefulDownload(videoId, title) {
        if (window.YTM_CONFIG && window.YTM_CONFIG.isPremium) {
            window.location.href = `/Subscription/Download?youtubeId=${videoId}&title=${encodeURIComponent(title)}`;
        } else {
            toastr.warning("Chỉ hội viên Premium mới có thể tải nhạc. Hãy nâng cấp ngay!");
        }
    }

    function playPlaylistShuffled(id) {
        if (typeof window.playPlaylist === 'function') {
            window.playPlaylist(id, true);
        }
    }


    async function toggleLike(songId, btn) {
        try {
            const formData = new FormData();
            formData.append('songId', songId);
            const res = await fetch('/Interaction/ToggleLike', { method: 'POST', body: formData });
            const data = await res.json();
            if(data.success) {
                if(data.isLiked) btn.classList.add('liked');
                else btn.classList.remove('liked');
            }
        } catch(e) {}
    }

    async function removeSong(event, playlistId, songId, btn) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }
        
        if (!confirm('Gỡ bài hát này khỏi playlist?')) return;
        
        try {
            const formData = new FormData();
            formData.append('playlistId', playlistId);
            formData.append('songId', songId);
            
            // Add Anti-Forgery Token if available
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            
            const res = await fetch('/Playlist/RemoveSong', { 
                method: 'POST', 
                body: formData,
                headers: token ? { "RequestVerificationToken": token } : {}
            });
            const data = await res.json();
            
            if (data.success) {
                $(btn).closest('tr').fadeOut(300, function() { 
                    $(this).remove(); 
                    // Update index numbers immediately
                    $('.row-index').each(function(idx) {
                        $(this).text(idx + 1);
                    });
                    
                    if ($('.song-row').length === 0) {
                        location.reload(); // Show empty state
                    }
                });
                if (typeof toastr !== 'undefined') toastr.success("Đã gỡ bài hát khỏi playlist");
            } else {
                if (typeof toastr !== 'undefined') toastr.error(data.message || "Lỗi khi gỡ bài hát");
            }
        } catch (e) {
            console.error(e);
            if (typeof toastr !== 'undefined') toastr.error("Lỗi kết nối máy chủ");
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // loadPlaylistSuggestions removed
    });
</script>
