@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.PlaylistDto>
@{
    ViewData["Title"] = "Thư viện của tôi";
}

<div class="library-container animate-fade-in">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="display-4 fw-black m-0 text-white">Thư viện</h1>
            <p class="text-dim m-0">Không gian âm nhạc riêng của bạn</p>
        </div>
        <button class="btn btn-accent rounded-pill px-4 py-2 fw-bold shadow-lg" data-bs-toggle="modal" data-bs-target="#createPlaylistModal">
            <i class="fa-solid fa-plus me-2"></i> Tạo Playlist mới
        </button>
    </div>

    <!-- DISCOVERY HUB -->
    @{
        var featured = ViewBag.FeaturedPlaylists as IEnumerable<YoutubeMusicPlayer.Application.DTOs.PlaylistDto>;
    }
    @if (featured != null && featured.Any())
    {
        <section class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <i class="fa-solid fa-compass fs-4 text-accent me-3"></i>
                <h3 class="m-0 fw-bold">Khám phá Playlist</h3>
            </div>
            
            <div class="horizontal-container">
                <div class="horizontal-carousel">
                    @foreach (var p in featured)
                    {
                        <div class="music-card group mini-card" onclick="window.location.href='/Playlist/Details/@p.PlaylistId'">
                            <div class="card-thumb-wrapper">
                                @if (string.IsNullOrEmpty(p.CoverImageUrl))
                                {
                                    <div class="card-thumb-placeholder">
                                        <i class="fa-solid fa-music"></i>
                                    </div>
                                }
                                else
                                {
                                    <img src="@p.CoverImageUrl" alt="@p.Title">
                                }
                                <div class="card-play-btn" onclick="event.stopPropagation(); playPlaylist(@p.PlaylistId)">
                                    <i class="fa-solid fa-play"></i>
                                </div>
                            </div>
                            <div class="card-content mt-2">
                                <h6 class="card-title text-main fw-bold mb-0 text-truncate">@p.Title</h6>
                                <p class="text-dim extra-small mb-0">@(p.FeaturedType ?? "Đề xuất")</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
        <hr class="border-white border-opacity-5 mb-5" />
    }

    <div class="mb-4">
        <h3 class="fw-bold mb-4">Playlist của tôi</h3>
    </div>

    <!-- PLAYLISTS GRID -->
    <div class="music-grid">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 glass-card">
                <div class="text-dim">
                    <i class="fa-solid fa-compact-disc display-1 d-block mb-4 opacity-10"></i>
                    <p class="fs-5">Bạn chưa có playlist nào.</p>
                    <button class="btn btn-outline-accent rounded-pill px-4 mt-2" data-bs-toggle="modal" data-bs-target="#createPlaylistModal">Bắt đầu ngay</button>
                </div>
            </div>
        }
        else
        {
            @foreach (var p in Model)
            {
                <div class="music-card group" onclick="window.location.href='/Playlist/Details/@p.PlaylistId'">
                    <div class="card-thumb-wrapper">
                        @if (string.IsNullOrEmpty(p.CoverImageUrl))
                        {
                            <div class="card-thumb-placeholder">
                                <i class="fa-solid fa-music"></i>
                            </div>
                        }
                        else
                        {
                            <img src="@p.CoverImageUrl" alt="@p.Title">
                        }
                        <div class="card-play-btn" onclick="event.stopPropagation(); playPlaylist(@p.PlaylistId)">
                            <i class="fa-solid fa-play"></i>
                        </div>
                    </div>
                    <div class="card-content mt-3">
                        <h6 class="card-title text-main fw-bold mb-1">@p.Title</h6>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-dim extra-small">@p.SongIds.Count() bài hát</span>
                            <div class="d-flex align-items-center gap-2">
                                <a asp-action="Edit" asp-route-id="@p.PlaylistId" onclick="event.stopPropagation();" class="btn btn-link text-dim hover-text-accent p-0 border-0 extra-small" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form asp-action="Delete" method="post" onsubmit="event.stopPropagation(); return confirm('Xóa playlist này?')" class="d-inline">
                                    <input type="hidden" name="playlistId" value="@p.PlaylistId" />
                                    <button type="submit" class="btn btn-link text-dim hover-text-danger p-0 border-0 extra-small" title="Xóa">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Create Playlist Modal -->
<div class="modal fade" id="createPlaylistModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-2xl overflow-hidden p-0">
            <div class="modal-header bg-gradient-accent border-0 p-4">
                <h5 class="modal-title fw-black text-white"><i class="fa-solid fa-folder-plus me-2"></i> Tạo Playlist</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 bg-dark bg-opacity-50">
                    <div class="mb-4">
                        <label class="form-label text-dim small uppercase tracking-wider fw-bold">Tên Playlist</label>
                        <input type="text" name="title" class="custom-input-simple" placeholder="Ví dụ: Nhạc chill cuối tuần..." required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label text-dim small uppercase tracking-wider fw-bold">Mô tả (Không bắt buộc)</label>
                        <textarea name="description" class="custom-input-simple" rows="3" placeholder="Ghi chú về playlist này..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-dark bg-opacity-50 border-0 p-4 pt-0">
                    <button type="button" class="btn btn-link text-dim text-decoration-none fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-accent rounded-pill px-4 fw-bold shadow-lg">Tạo ngay</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .library-container { padding-bottom: 50px; }
    
    .custom-input-simple {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        width: 100%;
        padding: 12px 16px;
        border-radius: 12px;
        outline: none;
        transition: 0.3s;
    }
    
    .custom-input-simple:focus {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--accent-primary);
    }
    
    .bg-gradient-accent {
        background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
    }

    .glass-card {
        background: rgba(40, 40, 40, 0.4);
        backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
    }
    
    .animate-fade-in {
        animation: fadeIn 0.8s ease-out;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .horizontal-container {
        overflow-x: auto;
        padding-bottom: 10px;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .horizontal-container::-webkit-scrollbar { display: none; }
    
    .horizontal-carousel {
        display: flex;
        gap: 20px;
        width: max-content;
    }
    
    .mini-card {
        width: 180px;
        flex-shrink: 0;
    }
    .mini-card .card-thumb-wrapper {
        aspect-ratio: 1/1;
        width: 100%;
    }
</style>
