@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.PlaylistDto>

@{
    ViewData["Title"] = "My Playlists";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="text-white fw-bold"><i class="bi bi-music-note-list me-2"></i> My Playlists</h2>
    <button class="btn btn-primary rounded-pill pe-4 ps-3 fw-bold" style="background: linear-gradient(45deg, #1db954, #1ed760); border: none;" data-bs-toggle="modal" data-bs-target="#createPlaylistModal">
        <i class="bi bi-plus-lg me-2"></i> Create Playlist
    </button>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="text-white-50 fs-5">
                <i class="bi bi-disc fs-1 d-block mb-3"></i>
                You don't have any playlists yet.<br/>
                Create one to start saving your favorite songs!
            </div>
        </div>
    }
    else
    {
        @foreach (var playlist in Model)
        {
            <div class="col">
                <div class="card bg-dark-glass h-100 border-secondary border-opacity-25 shadow-sm playlist-card">
                    <div class="position-relative">
                        <img src="@(playlist.CoverImageUrl ?? "/images/default-playlist.png")" class="card-img-top object-fit-cover" style="height: 200px; background-color: #282828;" alt="@playlist.Title">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title text-white fw-bold mb-1 text-truncate">@playlist.Title</h5>
                        <p class="card-text text-white-50 small mb-3">@playlist.SongIds.Count() songs</p>
                        <p class="card-text text-white-50 small text-truncate">@playlist.Description</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 d-flex justify-content-between">
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this playlist?');">
                            <input type="hidden" name="playlistId" value="@playlist.PlaylistId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash3"></i> Delete</button>
                        </form>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-pill px-3">View</a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Create Playlist Modal -->
<div class="modal fade" id="createPlaylistModal" tabindex="-1" aria-hidden="true" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title text-white">Create New Playlist</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="title" class="form-label text-white-50">Playlist Name</label>
                        <input type="text" class="form-control bg-dark border-secondary text-white rounded-3" id="title" name="title" required placeholder="e.g. Chill Vibes">
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label text-white-50">Description (Optional)</label>
                        <textarea class="form-control bg-dark border-secondary text-white rounded-3" id="description" name="description" rows="3" placeholder="Describe your playlist..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" style="background: linear-gradient(45deg, #1db954, #1ed760); border: none;">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
