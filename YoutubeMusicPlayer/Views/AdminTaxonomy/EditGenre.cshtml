@model YoutubeMusicPlayer.Application.DTOs.GenreDto
@{
    ViewData["Title"] = "Edit Genre";
}

<div class="container-fluid py-5 animate-fade-in">
    <div class="row justify-content-center px-lg-4">
        <div class="col-md-6 col-lg-5">
            <div class="mb-4">
                <a asp-controller="AdminTaxonomy" asp-action="Index" class="btn btn-outline-secondary btn-sm border-0 rounded-pill px-3 transition-hover">
                    <i class="bi bi-arrow-left me-1"></i> Back to Taxonomy
                </a>
                <h2 class="text-white fw-bold mt-3"><i class="bi bi-pencil-square me-2 text-info"></i> Update Genre</h2>
                <p class="text-muted small">Update the details for <strong>@Model.Name</strong>.</p>
            </div>

            <div class="glass-panel p-4 shadow-2xl overflow-hidden border-secondary border-opacity-10">
                <form asp-controller="AdminTaxonomy" asp-action="EditGenre" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="GenreId" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger extra-small mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label text-dim small uppercase fw-bold">Genre Name</label>
                        <input asp-for="Name" class="form-control bg-dark text-white border-secondary border-opacity-25 py-2" placeholder="Enter name...">
                        <span asp-validation-for="Name" class="text-danger extra-small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label text-dim small uppercase fw-bold">Genre Description</label>
                        <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary border-opacity-25 py-2" rows="4" placeholder="Enter details..."></textarea>
                        <span asp-validation-for="Description" class="text-danger extra-small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-info rounded-pill py-3 fw-bold shadow-sm">
                            <i class="bi bi-save me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
