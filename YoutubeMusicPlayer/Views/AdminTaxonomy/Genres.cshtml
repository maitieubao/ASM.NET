@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.GenreDto>
@{
    ViewData["Title"] = "Genre Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold"><i class="bi bi-music-note-list me-2 text-accent"></i> Genres</h2>
        <a asp-action="CreateGenre" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-lg me-1"></i> Add Genre
        </a>
    </div>

    <div class="card bg-dark-glass text-white border-secondary border-opacity-25 shadow-lg">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4 align-middle">
                <thead>
                    <tr class="text-white-50">
                        <th>ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.GenreId</td>
                            <td class="fw-bold text-white">@item.Name</td>
                            <td class="text-white-50 small">@item.Description</td>
                            <td>
                                <div class="btn-group">
                                    <a asp-action="EditGenre" asp-route-id="@item.GenreId" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="DeleteGenre" asp-route-id="@item.GenreId" method="post" onsubmit="return confirm('Attention! Deleting a genre will remove it from all songs. Continue?')" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
