@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.CommentDto>
@{
    ViewData["Title"] = "Comment Moderation";
}

<div class="container-fluid py-4 animate-fade-in">
    <div class="mb-5 d-flex justify-content-between align-items-center px-lg-4">
        <div>
            <h2 class="text-white fw-bold"><i class="bi bi-chat-square-dots-fill me-2 text-info"></i> Comment Moderation</h2>
            <p class="text-muted small mb-0">Manage user interactions and ensure a safe community.</p>
        </div>
        <div class="text-end">
            <div class="glass-panel p-2 d-flex" style="width: 350px;">
                <input type="text" id="comment-search" class="form-control bg-transparent border-0 text-white" placeholder="Filter current page...">
                <button type="button" class="btn btn-info btn-sm rounded-circle ms-2"><i class="bi bi-search"></i></button>
            </div>
        </div>
    </div>

    <div class="glass-panel p-0 overflow-hidden shadow-2xl mx-lg-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="text-white-50 border-bottom border-secondary border-opacity-10 extra-small uppercase">
                        <th class="ps-4 py-3">User</th>
                        <th>Comment Content</th>
                        <th>Target Song</th>
                        <th>Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="comment-list">
                    @foreach (var c in Model)
                    {
                        <tr class="comment-row border-bottom border-secondary border-opacity-10">
                            <td class="ps-4">
                                <div class="fw-bold text-white small">@c.UserName</div>
                                <div class="text-muted extra-small">ID: @c.UserId</div>
                            </td>
                            <td style="max-width: 400px;">
                                <div class="comment-content text-white small">@c.Content</div>
                            </td>
                            <td>
                                <div class="fw-bold text-info small">@c.SongTitle</div>
                                <div class="text-muted extra-small">ID: @c.SongId</div>
                            </td>
                            <td class="extra-small text-muted">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <form asp-controller="AdminSupport" asp-action="DeleteComment" asp-route-id="@c.CommentId" method="post" onsubmit="return confirm('Delete this comment?')" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle p-2 shadow-sm transition-hover">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="p-5 text-center">
                <i class="bi bi-chat-square-dots display-1 text-white opacity-10 mb-3"></i>
                <h4 class="text-muted">No comments found.</h4>
            </div>
        }
    </div>
</div>

<script>
    document.getElementById('comment-search').addEventListener('keyup', function() {
        var term = this.value.toLowerCase();
        var rows = document.querySelectorAll('.comment-row');
        rows.forEach(function(row) {
            var content = row.querySelector('.comment-content').textContent.toLowerCase();
            var user = row.querySelector('.fw-bold').textContent.toLowerCase();
            if(content.indexOf(term) > -1 || user.indexOf(term) > -1) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>
