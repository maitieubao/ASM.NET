@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.NotificationDto>
@{
    ViewData["Title"] = "System Notifications";
}

<div class="container-fluid py-4 animate-fade-in">
    <div class="row g-4 px-lg-4">
        <div class="col-lg-5">
            <div class="glass-panel text-white border-secondary border-opacity-10 shadow-lg p-4 h-100">
                <h3 class="fw-bold mb-4 text-warning"><i class="bi bi-megaphone-fill me-2"></i> Send Notification</h3>
                <form asp-controller="AdminSupport" asp-action="SendNotification" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label text-dim small uppercase fw-bold">Target User (Optional)</label>
                        <input type="number" name="userId" class="form-control bg-dark text-white border-secondary border-opacity-25" placeholder="Leave empty for all users">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dim small uppercase fw-bold">Title</label>
                        <input type="text" name="title" required class="form-control bg-dark text-white border-secondary border-opacity-25" placeholder="e.g. System Maintenance">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dim small uppercase fw-bold">Message Content</label>
                        <textarea name="message" required class="form-control bg-dark text-white border-secondary border-opacity-25" rows="4" placeholder="Enter your message..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold py-3 mt-2 shadow-sm rounded-pill">
                        <i class="bi bi-send-fill me-2"></i> Broadcast Notification
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="glass-panel text-white border-secondary border-opacity-10 shadow-lg p-0 h-100 overflow-hidden">
                <div class="p-4 border-bottom border-secondary border-opacity-10">
                    <h3 class="fw-bold mb-0 text-info"><i class="bi bi-history me-2"></i> History</h3>
                </div>
                <div class="table-responsive" style="max-height: 600px;">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead class="text-white-50 extra-small uppercase border-bottom border-secondary border-opacity-10">
                            <tr>
                                <th class="ps-4">Target</th>
                                <th>Content</th>
                                <th>Sent At</th>
                                <th class="text-end pe-4">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var n in Model)
                            {
                                <tr class="border-bottom border-secondary border-opacity-10">
                                    <td class="ps-4">
                                        <span class="badge @(n.UserId == null ? "bg-primary" : "bg-info") bg-opacity-10 text-@(n.UserId == null ? "primary" : "info") border border-@(n.UserId == null ? "primary" : "info") border-opacity-25 rounded-pill px-3">
                                            @(n.UserId == null ? "Broadcast" : "Direct: " + n.UserName)
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-white small">@n.Title</div>
                                        <div class="text-muted extra-small text-truncate" style="max-width: 250px;">@n.Message</div>
                                    </td>
                                    <td class="extra-small text-muted">
                                        @n.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-controller="AdminSupport" asp-action="DeleteNotification" asp-route-id="@n.NotificationId" method="post" class="d-inline" onsubmit="return confirm('Delete this record?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle p-2"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr><td colspan="4" class="text-center py-5 text-muted">No notifications sent yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-dark-glass { background: rgba(20, 20, 20, 0.8); backdrop-filter: blur(12px); }
</style>
