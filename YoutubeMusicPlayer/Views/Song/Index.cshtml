@model YoutubeMusicPlayer.Models.ViewModels.SongIndexViewModel

@{
    ViewData["Title"] = "Quản lý bài hát";
}

<div class="auth-card p-5 animate__animated animate__fadeIn">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show premium-glass border-0 text-white mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold mb-2">Thư viện bài hát</h1>
            <p class="text-muted small">Quản lý cơ sở dữ liệu nhạc và metadata của bạn.</p>
        </div>
        <div class="d-flex gap-3">
            <a asp-action="Import" class="btn btn-outline-danger border-danger border-opacity-25 rounded-pill px-4">
                <i class="fa-solid fa-bolt me-2"></i> Nhập nhanh
            </a>
            <a asp-action="Create" class="btn btn-primary premium-gradient border-0 rounded-pill px-5">
                <i class="fa-solid fa-plus me-2"></i> Thêm thủ công
            </a>
        </div>
    </div>

    <!-- Search Form -->
    <div class="mb-4">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <div class="input-group" style="max-width: 400px;">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control form-control-prem" placeholder="Tìm kiếm bài hát...">
            </div>
            <button type="submit" class="btn btn-secondary rounded-pill px-4">Tìm</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-link text-muted extra-small d-flex align-items-center">Xóa lọc</a>
            }
        </form>
    </div>

    <div class="table-responsive">
        <table class="modern-table">
            <thead>
                <tr>
                    <th>Tên bài hát</th>
                    <th>Thể loại</th>
                    <th>DỮ LIỆU YouTube</th>
                    <th>LƯỢT NGHE</th>
                    <th class="text-end">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Songs) {
                <tr>
                    <td>
                        <div class="fw-bold">@item.Title @(item.IsExplicit ? "🔞" : "")</div>
                        <div class="text-muted extra-small mt-1 px-1">ISRC: @item.Isrc</div>
                    </td>
                    <td>
                        @if (item.GenreNames != null && item.GenreNames.Any()) {
                            foreach (var gname in item.GenreNames) {
                                <span class="tag-badge me-1" style="font-size: 0.65rem;">@gname</span>
                            }
                        } else {
                            <span class="text-white-50 small">...</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.YoutubeVideoId)) {
                            <a href="https://youtube.com/watch?v=@item.YoutubeVideoId" target="_blank" class="text-accent small font-monospace">
                                <code>@item.YoutubeVideoId</code>
                            </a>
                        } else {
                            <span class="text-muted small">Chưa có ID</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-secondary bg-opacity-10 text-main fw-bold">@item.PlayCount.ToString("N0")</span>
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-3">
                             <a asp-action="Edit" asp-route-id="@item.SongId" class="text-dim hover-text-main"><i class="fa-solid fa-pen-to-square"></i></a>
                             <a asp-action="Delete" asp-route-id="@item.SongId" class="text-muted hover-text-danger"><i class="fa-solid fa-trash-can"></i></a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-5">
            <nav>
                <ul class="pagination pagination-prem">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    </li>
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
