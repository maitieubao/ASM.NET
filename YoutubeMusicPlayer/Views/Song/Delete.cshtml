@model YoutubeMusicPlayer.Application.DTOs.SongDto

@{
    ViewData["Title"] = "Confirm Delete";
}

<div class="container py-5">
    <div class="form-glass animate__animated animate__shakeX text-center" style="max-width: 500px; margin: 0 auto; border: 2px solid var(--accent-color);">
        <h2 class="text-danger fw-bold mb-4">Delete Song?</h2>
        <div class="mb-4">
             @if (!string.IsNullOrEmpty(Model.ThumbnailUrl)) {
                <img src="@Model.ThumbnailUrl" class="rounded mb-3" style="width: 200px; height: 110px; object-fit: cover;" />
            }
            <h4 class="mb-1">@Model.Title</h4>
            <p class="text-muted small">Are you sure you want to delete this song from library?</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" name="id" value="@Model.SongId" />
            <div class="d-flex justify-content-center gap-3 mt-5">
                <a asp-action="Index" class="btn-outline-prem">Back</a>
                <button type="submit" class="btn btn-danger px-5">Confirm Delete</button>
            </div>
        </form>
    </div>
</div>
