@model YoutubeMusicPlayer.Application.DTOs.ResetPasswordDto

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container py-5">
    <div class="glass-panel p-5 rounded-5 mx-auto" style="max-width: 450px;">
        <h1 class="display-6 fw-bold text-white mb-4 text-center">New Password</h1>
        
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info bg-info bg-opacity-10 border-info text-info rounded-pill px-4 small mb-4" role="alert">
                <i class="bi bi-info-circle me-2"></i> @TempData["Message"]
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <input type="hidden" asp-for="Email" />
            
            <div class="mb-3">
                <label asp-for="Token" class="form-label text-white-50">6-Digit Recovery Token</label>
                <input asp-for="Token" class="form-control bg-dark border-secondary text-white rounded-pill px-4 text-center fw-bold" placeholder="000000" maxlength="6" />
                <span asp-validation-for="Token" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label text-white-50">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control bg-dark border-secondary text-white rounded-pill px-4" placeholder="••••••••" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label text-white-50">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control bg-dark border-secondary text-white rounded-pill px-4" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold" style="background: linear-gradient(45deg, #1db954, #1ed760); border: none;">Reset Password</button>
            </div>
        </form>
    </div>
</div>
