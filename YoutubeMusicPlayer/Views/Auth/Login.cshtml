@model YoutubeMusicPlayer.Application.DTOs.LoginDto

@{
    ViewData["Title"] = "Log In";
}

<div class="container py-5">
    <div class="glass-panel p-5 rounded-5 mx-auto" style="max-width: 450px;">
        <h1 class="display-6 fw-bold text-white mb-4 text-center">Welcome Back</h1>
        
        <form asp-action="Login">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label asp-for="Email" class="form-label text-white-50">Email Address</label>
                <input asp-for="Email" class="form-control bg-dark border-secondary text-white rounded-pill px-4" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label text-white-50">Password</label>
                <input asp-for="Password" type="password" class="form-control bg-dark border-secondary text-white rounded-pill px-4" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label text-white-50">Remember Me</label>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold" style="background: linear-gradient(45deg, #1db954, #1ed760); border: none;">Log In</button>
            </div>
            
            <div class="text-center mb-3 text-white-50">OR</div>

            <div class="d-grid mb-4">
                <a asp-action="LoginWithGoogle" class="btn btn-outline-light rounded-pill py-2">
                    <i class="bi bi-google text-danger me-2"></i> Continue with Google
                </a>
            </div>

            <p class="text-center text-white-50 mt-4 mb-0">
                Don't have an account? <a asp-action="Register" class="text-white fw-bold text-decoration-none">Sign up</a>
            </p>
        </form>
    </div>
</div>
