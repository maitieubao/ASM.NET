@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container py-5">
    <div class="glass-panel p-5 rounded-5 mx-auto" style="max-width: 450px;">
        <h1 class="display-6 fw-bold text-white mb-4 text-center">Recover Password</h1>
        <p class="text-white-50 text-center mb-4">Enter your email address and we'll send you a recovery token.</p>
        
        <form asp-action="ForgotPassword" method="post">
            <div class="mb-4">
                <label for="email" class="form-label text-white-50">Email Address</label>
                <input type="email" id="email" name="email" class="form-control bg-dark border-secondary text-white rounded-pill px-4" placeholder="you@example.com" required />
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold" style="background: linear-gradient(45deg, #1db954, #1ed760); border: none;">Send Recovery Token</button>
            </div>
            
            <p class="text-center text-white-50 mt-4 mb-0">
                Remember your password? <a asp-action="Login" class="text-white fw-bold text-decoration-none">Log in</a>
            </p>
        </form>
    </div>
</div>
