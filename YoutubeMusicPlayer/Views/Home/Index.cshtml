@model YoutubeMusicPlayer.Models.HomeViewModel
@{
    ViewData["Title"] = "Khám phá - Música";
}

<div class="home-page-container">
    
    <!-- GREETING & QUICK ACCESS -->
    <div class="mb-4">
        <h1 class="greeting-text">@Model.Greeting</h1>
        <div class="tag-filters mt-3">
            <div class="tag-filter active" onclick="applyFilter(this, 'Tất cả')">Dành cho bạn</div>
            <div class="tag-filter" onclick="applyFilter(this, 'Chill')">Giai điệu Chill</div>
            <div class="tag-filter" onclick="applyFilter(this, 'Tập trung')">Tập trung làm việc</div>
            <div class="tag-filter" onclick="applyFilter(this, 'V-Pop hot')">V-Pop Hot</div>
            <div class="tag-filter" onclick="applyFilter(this, 'Sôi động')">Sôi động</div>
            <div class="tag-filter" onclick="applyFilter(this, 'Workout')">Tập thể dục</div>
            @foreach (var genre in Model.Genres.Take(5))
            {
                <div class="tag-filter" onclick="applyFilter(this, '@genre.Name')">@genre.Name</div>
            }
        </div>
    </div>

    <!-- 1. NGHE LẠI GẦN ĐÂY (High-Density Grid - Spotify Style) -->
    @if (Model.RecentListened != null && Model.RecentListened.Any())
    {
        <div class="mb-5">
            <div class="recent-grid">
                @foreach (var item in Model.RecentListened.Take(6))
                {
                    <div class="recent-card" onclick="playSingleTrack('@item.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Title)', '@System.Web.HttpUtility.JavaScriptStringEncode(item.AuthorName)', '@item.ThumbnailUrl')">
                        <img src="@item.ThumbnailUrl" alt="@item.Title">
                        <div class="recent-card-info">
                            <span class="recent-card-title">@item.Title</span>
                        </div>
                        <div class="recent-card-play"><i class="fa-solid fa-play"></i></div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- 2. DYNAMIC SECTIONS (Now Loaded via AJAX for Performance) -->
    <div id="home-dynamic-sections">
        <!-- Placeholders for AJAX loading -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="section-placeholder" data-type="mix1"></div>
            <div class="section-placeholder" data-type="mix2"></div>
            <div class="section-placeholder" data-type="mix3"></div>
            <div class="section-placeholder" data-type="Contextual"></div>
        }
        else
        {
            <div class="section-placeholder" data-type="mix1"></div>
        }
        
        <div class="section-placeholder" data-type="topcharts_vn"></div>
        <div class="section-placeholder" data-type="Trending"></div>
        <div class="section-placeholder" data-type="topcharts_global"></div>
        <div class="section-placeholder" data-type="Focus"></div>
        <div class="section-placeholder" data-type="Chill"></div>
        <div class="section-placeholder" data-type="Sad"></div>
        <div class="section-placeholder" data-type="Albums"></div>
    </div>

    <!-- 3. TOP NGHỆ SĨ (Circular Cards) -->
    @if (Model.TopArtists != null && Model.TopArtists.Any())
    {
        <div class="mb-5 section-reveal">
            <div class="section-header align-items-center mb-3">
                <h2 class="section-title">Nghệ sĩ dành cho bạn</h2>
            </div>
            <div class="carousel-wrapper">
                <button class="carousel-nav carousel-prev" onclick="scrollCarousel(this, -1)"><i class="fa-solid fa-chevron-left"></i></button>
                <button class="carousel-nav carousel-next" onclick="scrollCarousel(this, 1)"><i class="fa-solid fa-chevron-right"></i></button>
                <div class="horizontal-carousel scrollbar-hide">
                    @foreach (var artist in Model.TopArtists.Take(10))
                    {
                        <div class="artist-card" onclick="window.location.href='/Artist/Details/@artist.ArtistId'">
                            <img src="@(artist.AvatarUrl ?? "https://ui-avatars.com/api/?name="+artist.Name)" alt="@artist.Name" class="artist-thumb">
                            <div class="artist-info mt-2 text-center">
                                <div class="ytm-card-title text-center">@artist.Name</div>
                                <div class="ytm-card-meta">Nghệ sĩ</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- 4. SEARCH RESULTS (Hidden by default, swapped via AJAX) -->
    <div id="search-results-main" style="display: none;" class="section-reveal">
        <div class="section-header d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title" id="search-query-title">Kết quả tìm kiếm</h2>
            <button class="btn btn-link text-accent fw-bold text-decoration-none" onclick="exitSearchMode()">
                <i class="fa-solid fa-xmark me-2"></i> Đóng tìm kiếm
            </button>
        </div>
        <div id="search-results-content" class="song-list-grid">
            <!-- Results will be injected here -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const placeholders = document.querySelectorAll('.section-placeholder');
            
            async function loadSections() {
                for (const el of placeholders) {
                    const type = el.getAttribute('data-type');
                    try {
                        const response = await fetch(`/Home/GetHomeSection?type=${type}`);
                        const html = await response.text();
                        if (html && html.trim().length > 0) {
                            el.innerHTML = html;
                            el.classList.add('loaded');
                            if (window.ScrollReveal) window.ScrollReveal().reveal(el.querySelector('.section-reveal'));
                        } else {
                            el.remove();
                        }
                    } catch (err) {
                        console.error('Error loading section:', type, err);
                        el.remove();
                    }
                }
            }
            
            loadSections();
        });

        function scrollCarousel(btn, direction) {
            const container = btn.closest('.mb-5').querySelector('.horizontal-carousel') || btn.closest('.mb-5').querySelector('.song-list-grid');
            if (container) {
                container.scrollBy({ left: direction * 500, behavior: 'smooth' });
            }
        }

        async function applyFilter(btn, tag) {
            if (tag === 'Tất cả') {
                window.location.href = '/';
                return;
            }
            document.querySelectorAll('.tag-filter').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            window.location.href = `/Home/Discovery?tag=${encodeURIComponent(tag)}`;
        }
    </script>
}
