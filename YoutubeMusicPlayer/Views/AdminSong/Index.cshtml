@model YoutubeMusicPlayer.Models.Admin.AdminSongListViewModel
@{
    ViewData["Title"] = "Quản lý Bài hát";
}

<div class="container-fluid mt-4 pb-5 px-lg-5 text-white animate-fade-in" style="padding-right: 160px !important;">
    @Html.AntiForgeryToken()
    <!-- Mini Analytics (Optional/Static for now) -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden">
                <div class="text-dim uppercase small fw-bold mb-1">Bài hát hiển thị</div>
                <div class="fs-1 fw-black">@Model.Songs.Count()</div>
                <i class="fa-solid fa-music position-absolute text-white opacity-5" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden">
                <div class="text-dim uppercase small fw-bold mb-1">Trang hiện tại</div>
                <div class="fs-1 fw-black text-accent">@Model.CurrentPage</div>
                <i class="fa-solid fa-file-lines position-absolute text-accent opacity-5" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden">
                <div class="text-dim uppercase small fw-bold mb-1">Premium Only</div>
                <div class="fs-1 fw-black text-warning">@Model.Songs.Count(s => s.IsPremiumOnly)</div>
                <i class="fa-solid fa-gem position-absolute text-warning opacity-5" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
        <div class="col-md-3">
             <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden bg-danger bg-opacity-10">
                <div class="text-danger-emphasis uppercase small fw-bold mb-1">Explicit Content</div>
                <div class="fs-1 fw-black text-danger">@Model.Songs.Count(s => s.IsExplicit)</div>
                <i class="fa-solid fa-triangle-exclamation position-absolute text-danger opacity-10" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <h2 class="fw-black m-0">Thư viện Bài hát</h2>
            <a asp-controller="AdminSong" asp-action="Create" class="btn btn-warning rounded-pill px-4 fw-bold">
                <i class="fa-solid fa-plus me-2"></i>Thêm bài hát
            </a>
        </div>
        <div class="d-flex gap-2">
            <form asp-controller="AdminSong" asp-action="Index" method="get" class="glass-panel p-2 d-flex" style="width: 350px;">
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control bg-transparent border-0 text-white" placeholder="Tìm theo tên bài hát..." />
                <button type="submit" class="btn btn-warning btn-sm rounded-circle ms-2"><i class="fa-solid fa-magnifying-glass"></i></button>
            </form>
        </div>
    </div>

    <!-- Data Table -->
    <div class="glass-panel p-0 overflow-hidden shadow-2xl">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle admin-table">
                <thead>
                    <tr class="text-white-50 border-bottom border-secondary border-opacity-10">
                        <th class="ps-4">Thông tin bài hát</th>
                        <th>Video ID</th>
                        <th>Premium</th>
                        <th>Explicit</th>
                        <th>Lượt phát</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Songs)
                    {
                        <tr class="border-bottom border-secondary border-opacity-10">
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@s.ThumbnailUrl" class="rounded-3 border border-secondary border-opacity-25" style="width: 50px; height: 50px; object-fit: cover;">
                                    <div>
                                        <div class="fw-bold text-white">@s.Title</div>
                                        <div class="text-muted extra-small">Added: @s.ReleaseDate?.ToString("dd/MM/yyyy")</div>
                                    </div>
                                </div>
                            </td>
                            <td><code class="text-accent">@s.YoutubeVideoId</code></td>
                            <td>
                                <div class="form-check form-switch p-0 m-0">
                                    <input class="form-check-input ms-0 cursor-pointer" type="checkbox" role="switch" 
                                           @(s.IsPremiumOnly ? "checked" : "") onclick="toggleSongPremium(@s.SongId, this)">
                                </div>
                            </td>
                             <td>
                                <div class="form-check form-switch p-0 m-0">
                                    <input class="form-check-input ms-0 cursor-pointer" type="checkbox" role="switch" 
                                           @(s.IsExplicit ? "checked" : "") onclick="toggleSongExplicit(@s.SongId, this)">
                                </div>
                            </td>
                            <td><span class="text-accent fw-bold">@s.PlayCount.ToString("N0")</span></td>
                            <td class="text-end pe-4">
                                <div class="btn-group gap-2">
                                    <a asp-controller="AdminSong" asp-action="Edit" asp-route-id="@s.SongId" class="btn btn-sm btn-outline-info rounded-3" title="Chỉnh sửa"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <form asp-controller="AdminSong" asp-action="Delete" asp-route-id="@s.SongId" method="post" onsubmit="return confirm('Xóa bài hát này (Soft Delete)?')" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Xóa"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-4 border-top border-secondary border-opacity-10">
                <div class="extra-small text-muted">Trang @Model.CurrentPage của @Model.TotalPages</div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm">Pre</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link rounded-2 @(Model.CurrentPage == i ? "bg-warning border-warning text-dark" : "bg-dark border-secondary border-opacity-25 text-white")" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        async function toggleSongPremium(id, input) {
            try {
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';
                const res = await fetch(`/AdminSong/TogglePremium/${id}`, { 
                    method: 'POST', 
                    headers: { 
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    } 
                });
                if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
                const data = await res.json();
                if(data.success && typeof showToast !== 'undefined') showToast('Cập nhật quyền truy cập Premium thành công', 'success');
            } catch(e) { 
                console.error("Fetch error:", e);
                input.checked = !input.checked; 
            }
        }
        async function toggleSongExplicit(id, input) {
            try {
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';
                const res = await fetch(`/AdminSong/ToggleExplicit/${id}`, { 
                    method: 'POST', 
                    headers: { 
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    } 
                });
                if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
                const data = await res.json();
                if(data.success && typeof showToast !== 'undefined') showToast('Cập nhật gắn nhãn Explicit thành công', 'success');
            } catch(e) { 
                console.error("Fetch error:", e);
                input.checked = !input.checked; 
            }
        }
    </script>
}

<style>
    .admin-table thead th { background: rgba(255,255,255,0.02); color: #888; text-transform: uppercase; font-size: 11px; padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .admin-table tbody td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .btn-icon-small { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; color: #888; transition: 0.2s; border-radius: 8px; }
    .btn-icon-small:hover { background: rgba(255,255,255,0.1); color: white; }
</style>

<style>
    .admin-table thead th { background: rgba(255,255,255,0.02); color: #888; text-transform: uppercase; font-size: 11px; padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .admin-table tbody td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .btn-icon-small { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; color: #888; transition: 0.2s; border-radius: 8px; }
    .btn-icon-small:hover { background: rgba(255,255,255,0.1); color: white; }
</style>
