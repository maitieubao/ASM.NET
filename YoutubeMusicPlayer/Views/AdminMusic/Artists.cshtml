@model YoutubeMusicPlayer.Models.Admin.AdminArtistListViewModel
@{
    ViewData["Title"] = "Quản lý Nghệ sĩ";
}

<div class="container-fluid mt-4 pb-5 px-lg-5 text-white animate-fade-in">
    <!-- Analytics Header -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden">
                <div class="text-dim uppercase small fw-bold mb-1">Nghệ sĩ hiển thị</div>
                <div class="fs-1 fw-black">@Model.Artists.Count()</div>
                <i class="fa-solid fa-microphone-lines position-absolute text-white opacity-5" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden">
                <div class="text-dim uppercase small fw-bold mb-1">Trang hiện tại</div>
                <div class="fs-1 fw-black text-info">@Model.CurrentPage</div>
                <i class="fa-solid fa-file-invoice position-absolute text-info opacity-5" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel p-4 rounded-5 border-0 shadow-lg position-relative overflow-hidden">
                <div class="text-dim uppercase small fw-bold mb-1">Tổng cộng nghệ sĩ</div>
                <div class="fs-1 fw-black text-accent">@Model.Artists.Count()</div>
                <i class="fa-solid fa-chart-line position-absolute text-accent opacity-5" style="font-size: 80px; bottom: -10px; right: 10px;"></i>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <h2 class="fw-black m-0">Danh sách Nghệ sĩ</h2>
            <a asp-controller="AdminMusic" asp-action="CreateArtist" class="btn btn-warning rounded-pill px-4 fw-bold">
                <i class="fa-solid fa-plus me-2"></i>Thêm nghệ sĩ
            </a>
        </div>
        <div class="d-flex gap-2">
            <form asp-controller="AdminMusic" asp-action="Artists" method="get" class="glass-panel p-2 d-flex" style="width: 350px;">
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control bg-transparent border-0 text-white" placeholder="Tìm tên nghệ sĩ..." />
                <button type="submit" class="btn btn-warning btn-sm rounded-circle ms-2"><i class="fa-solid fa-magnifying-glass"></i></button>
            </form>
        </div>
    </div>

    <!-- Data Table -->
    <div class="glass-panel p-0 overflow-hidden shadow-2xl">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle admin-table">
                <thead>
                    <tr class="text-white-50 border-bottom border-secondary border-opacity-10">
                        <th class="ps-4">Nghệ sĩ</th>
                        <th>Trạng thái</th>
                        <th>Quốc gia</th>
                        <th>Người theo dõi</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Artists)
                    {
                        <tr class="border-bottom border-secondary border-opacity-10">
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@a.AvatarUrl" class="rounded-pill border border-secondary border-opacity-25" style="width: 44px; height: 44px; object-fit: cover;">
                                    <div class="fw-bold text-white">@a.Name</div>
                                </div>
                            </td>
                            <td>
                                <div class="form-check form-switch p-0 m-0 d-flex align-items-center gap-2">
                                    <input class="form-check-input ms-0 cursor-pointer" type="checkbox" role="switch" 
                                           @(a.IsVerified ? "checked" : "") onclick="toggleVerify(@a.ArtistId, this)">
                                    <span class="badge @(a.IsVerified ? "bg-info" : "bg-secondary") rounded-pill x-small">
                                        @(a.IsVerified ? "Verified" : "Unverified")
                                    </span>
                                </div>
                            </td>
                            <td><span class="text-muted small">@a.Country</span></td>
                            <td><span class="text-accent fw-bold">@a.SubscriberCount.ToString("N0")</span></td>
                            <td class="text-end pe-4">
                                <div class="btn-group gap-2">
                                    <a asp-controller="AdminMusic" asp-action="EditArtist" asp-route-id="@a.ArtistId" class="btn btn-sm btn-outline-info rounded-3" title="Chỉnh sửa"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <form asp-controller="AdminMusic" asp-action="DeleteArtist" asp-route-id="@a.ArtistId" method="post" onsubmit="return confirm('Xóa nghệ sĩ này (Soft Delete)?')" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Xóa"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if(!Model.Artists.Any()) {
            <div class="p-5 text-center">
                <i class="fa-solid fa-ghost display-1 text-white opacity-10 mb-3"></i>
                <h4 class="text-dim">Không tìm thấy nghệ sĩ nào phù hợp</h4>
            </div>
        }
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-4 border-top border-secondary border-opacity-10">
                <div class="extra-small text-muted">Trang @Model.CurrentPage của @Model.TotalPages</div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Artists" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm">Pre</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link rounded-2 @(Model.CurrentPage == i ? "bg-warning border-warning text-dark" : "bg-dark border-secondary border-opacity-25 text-white")" asp-action="Artists" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Artists" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        async function toggleVerify(id, input) {
            try {
                const res = await fetch(`/AdminMusic/ToggleArtistVerified/${id}`, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    const badge = input.nextElementSibling;
                    const isVerified = input.checked;
                    if(isVerified) {
                        badge.className = 'badge bg-info rounded-pill x-small';
                        badge.innerText = 'Verified';
                    } else {
                        badge.className = 'badge bg-secondary rounded-pill x-small';
                        badge.innerText = 'Unverified';
                    }
                }
            } catch(e) {
                input.checked = !input.checked;
            }
        }
    </script>
}

<style>
    .admin-table thead th { background: rgba(255,255,255,0.02); color: #888; text-transform: uppercase; font-size: 11px; padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .admin-table tbody td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .x-small { font-size: 10px; }
</style>

@section Scripts {
    <script>
        async function toggleVerify(id, input) {
            try {
                const res = await fetch(`/Admin/ToggleArtistVerify/${id}`, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    const badge = input.nextElementSibling;
                    if(data.isVerified) {
                        badge.className = 'badge bg-info rounded-pill x-small';
                        badge.innerText = 'Verified';
                    } else {
                        badge.className = 'badge bg-secondary rounded-pill x-small';
                        badge.innerText = 'Unverified';
                    }
                    showToast('Cập nhật trạng thái xác minh thành công', 'success');
                }
            } catch(e) {
                input.checked = !input.checked;
            }
        }
    </script>
}

<style>
    .admin-table thead th { background: rgba(255,255,255,0.02); color: #888; text-transform: uppercase; font-size: 11px; padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .admin-table tbody td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .btn-icon-small { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; color: #888; transition: 0.2s; border-radius: 8px; }
    .btn-icon-small:hover { background: rgba(255,255,255,0.1); color: white; }
    .x-small { font-size: 10px; }
</style>
