@model YoutubeMusicPlayer.Models.Admin.AdminPlaylistListViewModel
@{
    ViewData["Title"] = "Featured Playlists Management";
}

<div class="container-fluid py-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 px-lg-4">
        <div>
            <h2 class="text-white fw-bold"><i class="bi bi-star-fill me-2 text-warning"></i> Featured Playlists</h2>
            <p class="text-muted small mb-0">Curated collections for trending, hits, and discovery.</p>
        </div>
        <div class="d-flex gap-3">
             <form asp-controller="AdminPlaylist" asp-action="Index" method="get" class="glass-panel p-2 d-flex" style="width: 350px;">
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control bg-transparent border-0 text-white" placeholder="Search playlists..." />
                <button type="submit" class="btn btn-warning btn-sm rounded-circle ms-2"><i class="bi bi-search"></i></button>
            </form>
            <a asp-controller="AdminPlaylist" asp-action="CreateFeatured" class="btn btn-warning rounded-pill px-4 fw-bold">
                <i class="bi bi-plus-lg me-1"></i> New System Playlist
            </a>
        </div>
    </div>

    <div class="glass-panel p-0 overflow-hidden shadow-2xl mx-lg-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="text-white-50 border-bottom border-secondary border-opacity-10">
                        <th class="ps-4 py-3">Playlist Info</th>
                        <th>Type</th>
                        <th>Created At</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Playlists)
                    {
                        <tr class="border-bottom border-secondary border-opacity-10">
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(item.CoverImageUrl) ? "https://ui-avatars.com/api/?name=" + item.Title : item.CoverImageUrl)" 
                                         class="rounded shadow-sm border border-secondary border-opacity-25" width="50" height="50" style="object-fit: cover;">
                                    <div>
                                        <div class="fw-bold text-white">@item.Title</div>
                                        <div class="text-muted extra-small">@item.Description</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(item.FeaturedType == "Trending" ? "bg-info" : (item.FeaturedType == "TopHits" ? "bg-danger" : "bg-success")) rounded-pill px-3">
                                    @item.FeaturedType
                                </span>
                            </td>
                            <td><span class="text-muted small">@item.SongsCount songs</span></td>
                            <td class="text-end pe-4">
                                <div class="btn-group gap-2">
                                    <a asp-controller="AdminPlaylist" asp-action="EditFeatured" asp-route-id="@item.PlaylistId" class="btn btn-sm btn-outline-info rounded-3" title="Manage Songs">
                                        <i class="bi bi-gear-fill"></i>
                                    </a>
                                    <form asp-controller="AdminPlaylist" asp-action="Delete" asp-route-id="@item.PlaylistId" method="post" onsubmit="return confirm('Soft-delete this system playlist?')" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Playlists.Any())
        {
            <div class="p-5 text-center">
                <i class="bi bi-collection-play display-1 text-white opacity-10 mb-3"></i>
                <h4 class="text-muted">No playlists found.</h4>
            </div>
        }

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-4 border-top border-secondary border-opacity-10">
                <div class="extra-small text-muted">Page @Model.CurrentPage of @Model.TotalPages</div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm">Pre</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link rounded-2 @(Model.CurrentPage == i ? "bg-warning border-warning text-dark" : "bg-dark border-secondary border-opacity-25 text-white")" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
