@model YoutubeMusicPlayer.Models.Admin.AdminUserListViewModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold"><i class="bi bi-people-fill me-2 text-accent"></i> User Management</h2>
        <form asp-controller="AdminUser" asp-action="Index" method="get" class="d-flex glass-panel p-2">
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control me-2 bg-dark text-white border-secondary border-opacity-25" placeholder="Search users...">
            <button type="submit" class="btn btn-warning"><i class="bi bi-search"></i></button>
        </form>
    </div>

    <div class="glass-panel p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="text-white-50 border-bottom border-secondary border-opacity-10">
                        <th class="ps-4 py-3">User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr class="border-bottom border-secondary border-opacity-10">
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + user.Username : user.AvatarUrl)" 
                                         class="rounded-circle border border-secondary border-opacity-25" width="40" height="40" style="object-fit: cover;">
                                    <div>
                                        <div class="fw-600 text-white">@user.Username</div>
                                        <div class="extra-small text-muted">ID: #@user.UserId</div>
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary") rounded-pill">@user.Role</span>
                                @if (user.IsPremium)
                                {
                                    <span class="badge bg-warning text-dark rounded-pill ms-1"><i class="bi bi-gem me-1"></i>Premium</span>
                                }
                            </td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill">Active</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group gap-2">
                                    <a asp-controller="AdminUser" asp-action="Details" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-info rounded-3" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-controller="AdminUser" asp-action="TogglePremium" asp-route-id="@user.UserId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning rounded-3" title="Toggle Premium">
                                            <i class="bi bi-gem"></i>
                                        </button>
                                    </form>
                                    @if (user.Role != "Admin")
                                    {
                                        <form asp-controller="AdminUser" asp-action="Delete" asp-route-id="@user.UserId" method="post" onsubmit="return confirm('Are you sure you want to soft-delete this user?')" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-4 border-top border-secondary border-opacity-10">
                <div class="extra-small text-muted">Page @Model.CurrentPage of @Model.TotalPages</div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm">Pre</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link rounded-2 @(Model.CurrentPage == i ? "bg-warning border-warning text-dark" : "bg-dark border-secondary border-opacity-25 text-white")" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-2 bg-dark border-secondary border-opacity-25" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
