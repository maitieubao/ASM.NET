@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.GenreDto>

@{
    ViewData["Title"] = "Music Genres";
}

<div class="container-fluid py-5">
    <div class="glass-panel p-4 rounded-5">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-black text-white m-0">Library Categories</h1>
                <p class="text-white-50">Manage your music genres and classifications</p>
            </div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 border-0 shadow-sm" style="background: linear-gradient(45deg, #1db954, #1ed760);">
                <i class="bi bi-tag-fill me-2"></i> New Genre
            </a>
        </div>

        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-md-3">
                    <div class="card bg-dark border-secondary border-opacity-10 h-100 rounded-4 hover-lift">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3">#@item.GenreId</span>
                                    <div class="dropdown">
                                        <button class="btn btn-link text-white-50 p-0" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end border-secondary border-opacity-25 shadow">
                                            <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.GenreId"><i class="bi bi-pencil me-2"></i> Rename</a></li>
                                            <li><hr class="dropdown-divider border-secondary border-opacity-25"></li>
                                            <li><a class="dropdown-item py-2 text-danger" asp-action="Delete" asp-route-id="@item.GenreId"><i class="bi bi-trash me-2"></i> Delete</a></li>
                                        </ul>
                                    </div>
                                </div>
                                <h3 class="h4 fw-bold text-white mb-0">@item.Name</h3>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-tags display-1 text-white-10"></i>
                </div>
                <h3 class="text-white-50">No genres found</h3>
                <p class="text-muted">Start by adding a new genre like Pop, Rock, or Jazz.</p>
                <a asp-action="Create" class="btn btn-outline-light rounded-pill px-4 mt-2 border-opacity-25">Add First Genre</a>
            </div>
        }
    </div>
</div>
