@model YoutubeMusicPlayer.Application.DTOs.AlbumDto
@{
    ViewData["Title"] = "Edit Album Metadata";
}

<div class="container mt-4 pb-5 text-white">
    <div class="mb-5">
        <h2 class="fw-bold"><i class="bi bi-pencil-square me-2 text-info"></i> Edit Album Metadata</h2>
        <p class="text-white-50">Adjust album details and Discography properties.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card bg-dark text-white border-secondary border-opacity-25 shadow p-4 text-center">
                <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl) ? "/images/default-album.png" : Model.CoverImageUrl)" class="rounded shadow-lg mb-3 mx-auto w-100" style="aspect-ratio: 1; object-fit: cover;">
                <div class="fw-bold fs-4">@Model.Title</div>
                <div class="text-white-50 small mb-4">Type: @Model.AlbumType</div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card bg-dark-glass text-white border-secondary border-opacity-25 shadow-lg p-5">
                <form asp-action="EditAlbum" method="post">
                    <input type="hidden" asp-for="AlbumId" />
                    
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label text-white-50">Album Title</label>
                            <input asp-for="Title" class="form-control bg-dark text-white border-secondary" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-white-50">Album Type (Album/EP/Single)</label>
                            <input asp-for="AlbumType" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Album" />
                        </div>

                         <div class="col-md-6">
                            <label class="form-label text-white-50">Release Date</label>
                            <input asp-for="ReleaseDate" type="date" class="form-control bg-dark text-white border-secondary" />
                        </div>

                        <div class="col-12">
                            <label class="form-label text-white-50">Cover Image URL</label>
                            <input asp-for="CoverImageUrl" class="form-control bg-dark text-white border-secondary" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-white-50">Record Label</label>
                            <input asp-for="RecordLabel" class="form-control bg-dark text-white border-secondary" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-white-50">UPC Code</label>
                            <input asp-for="Upc" class="form-control bg-dark text-white border-secondary" />
                        </div>

                        <div class="col-md-4 mt-4">
                           <div class="form-check form-switch p-3 bg-dark border border-secondary border-opacity-10 rounded">
                                <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="IsExplicit">
                                <label class="form-check-label text-white-50">Explicit Content</label>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <hr class="border-secondary border-opacity-25">
                            <div class="d-flex justify-content-between">
                                <a asp-action="Albums" class="btn btn-outline-light px-4">Cancel</a>
                                <button type="submit" class="btn btn-info px-5 fw-bold text-dark shadow-sm">Save Changes</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-dark-glass { background: rgba(30,30,30,0.8); backdrop-filter: blur(10px); }
</style>
