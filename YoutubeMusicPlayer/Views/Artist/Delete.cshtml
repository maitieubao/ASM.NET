@model YoutubeMusicPlayer.Application.DTOs.ArtistDto

@{
    ViewData["Title"] = "Confirm Delete";
}

<div class="container py-5">
    <div class="form-glass animate__animated animate__shakeX text-center" style="max-width: 500px; margin: 0 auto; border: 2px solid var(--accent-color);">
        <h2 class="text-danger fw-bold mb-4">Delete Artist?</h2>
        <div class="mb-4">
             @if (!string.IsNullOrEmpty(Model.AvatarUrl)) {
                <img src="@Model.AvatarUrl" class="rounded-circle mb-3" style="width: 100px; height: 100px; object-fit: cover;" />
            }
            <h4 class="mb-1">@Model.Name</h4>
            <p class="text-muted small">Are you sure you want to PERMANENTLY delete this artist? This cannot be undone.</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" name="id" value="@Model.ArtistId" />
            <div class="d-flex justify-content-center gap-3 mt-5">
                <a asp-action="Index" class="btn-outline-prem">Cancel</a>
                <button type="submit" class="btn btn-danger px-5">Confirm Delete</button>
            </div>
        </form>
    </div>
</div>
