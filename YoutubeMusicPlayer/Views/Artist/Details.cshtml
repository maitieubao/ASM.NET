@model YoutubeMusicPlayer.Application.DTOs.ArtistDto
@{
    ViewData["Title"] = Model.Name + " - Nghệ sĩ";
}

<div class="artist-details-page animate-fade-in relative">
    <!-- 1. ARTIST HEADER (Stunning Banner) -->
    <div class="artist-header-hero relative overflow-hidden">
        <div class="artist-banner-bg" style="background-image: url('@(Model.BannerUrl ?? "https://images.unsplash.com/photo-1493225255756-d9584f8606e9?q=80&w=2000")');"></div>
        <div class="banner-gradient"></div>
        
        <div class="container relative z-10 pt-5 mt-5">
            <div class="d-flex align-items-end gap-4 pb-5">
                <div class="artist-avatar-wrapper shadow-2xl">
                    <img src="@(Model.AvatarUrl ?? "https://ui-avatars.com/api/?name=" + Model.Name + "&size=300")" class="artist-avatar-main">
                </div>
                <div class="mb-2">
                    @if (Model.IsVerified)
                    {
                        <div class="d-flex align-items-center gap-2 text-accent mb-2 fw-bold">
                            <i class="fa-solid fa-circle-check fs-5"></i> Nghệ sĩ đã xác minh
                        </div>
                    }
                    <h1 class="artist-title-large fw-black text-white m-0">@Model.Name</h1>
                    <div class="d-flex align-items-center gap-3 mt-3">
                        <span class="text-white-50 fw-bold"><i class="fa-solid fa-users me-2"></i> @Model.MonthlyListeners người nghe hằng tháng</span>
                        <div class="dot-separator"></div>
                        <span class="text-white-50 fw-bold">@Model.SubscriberCount.ToString("N0") người theo dõi</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. ACTION BAR (Sticky) -->
    <div class="sticky-top-actions glass-card backdrop-blur border-0 border-bottom border-white border-opacity-10 py-3 z-50">
        <div class="container d-flex align-items-center gap-4">
            <button class="btn-play-rounded shadow-accent" onclick="playArtistTopTracks(@Model.ArtistId)">
                <i class="fa-solid fa-play"></i>
            </button>
            <button id="followBtn" class="btn btn-outline-light rounded-pill px-4 fw-bold uppercase @(Model.IsFollowing ? "following" : "")" 
                    onclick="toggleFollow(@Model.ArtistId)">
                @(Model.IsFollowing ? "Đang theo dõi" : "Theo dõi")
            </button>
            <button class="btn btn-link text-white-50 p-2" title="Chia sẻ"><i class="fa-solid fa-share-nodes fs-5"></i></button>
            <div class="ms-auto d-none d-md-flex align-items-center gap-4">
                <a href="#popular" class="action-nav-link active">Phổ biến</a>
                <a href="#discography" class="action-nav-link">Sự nghiệp</a>
                <a href="#about" class="action-nav-link">Giới thiệu</a>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-5">
            <!-- LEFT CONTENT: Popular Songs & Discography -->
            <div class="col-lg-8">
                <!-- A. POPULAR SONGS -->
                <section id="popular" class="mb-5 section-reveal">
                    <h3 class="section-title mb-4">Phổ biến</h3>
                    <div class="popular-list">
                        @for (int i = 0; i < Model.TopSongs.Count(); i++)
                        {
                            var song = Model.TopSongs.ElementAt(i);
                            <div class="song-row-premium group" onclick="playSingleTrack('@song.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(song.Title)', '@System.Web.HttpUtility.JavaScriptStringEncode(Model.Name)', '@song.ThumbnailUrl')">
                                <div class="rank">@(i + 1)</div>
                                <div class="thumb-wrapper">
                                    <img src="@song.ThumbnailUrl">
                                    <div class="play-icon"><i class="fa-solid fa-play"></i></div>
                                </div>
                                <div class="title-meta">
                                    <div class="song-title">
                                        @song.Title
                                        @if(song.IsExplicit){ <span class="badge-explicit">E</span> }
                                        @if(song.IsPremiumOnly){ <i class="fa-solid fa-gem text-accent ms-1" title="Premium Only"></i> }
                                    </div>
                                </div>
                                <div class="plays">@song.PlayCount.ToString("N0")</div>
                                <div class="actions">
                                    <button class="btn-icon" onclick="event.stopPropagation(); toggleLikeByYoutubeId('@song.YoutubeVideoId', this)">
                                        <i class="fa-solid fa-heart"></i>
                                    </button>
                                    <button class="btn-icon" onclick="event.stopPropagation(); openAddToPlaylist(@song.SongId, '@song.YoutubeVideoId')">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                    <div class="duration">@(song.Duration.HasValue ? TimeSpan.FromSeconds(song.Duration.Value).ToString(@"m\:ss") : "--:--")</div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <!-- B. DISCOGRAPHY (Albums) -->
                @if (Model.Albums.Any())
                {
                    <section id="discography" class="mb-5 section-reveal">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h3 class="section-title">Sự nghiệp (Discography)</h3>
                            <div class="d-flex gap-2">
                                <button class="btn-pill-filter active">Tất cả</button>
                                <button class="btn-pill-filter">Album</button>
                                <button class="btn-pill-filter">Single & EP</button>
                            </div>
                        </div>
                        <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-4">
                            @foreach (var album in Model.Albums)
                            {
                                <div class="col">
                                    <div class="album-card-pro group" onclick="window.location.href='/Album/Details/@album.AlbumId'">
                                        <div class="cover-wrapper mb-3">
                                            <img src="@(album.CoverImageUrl ?? "https://placehold.co/400x400/222/white?text=" + album.Title)" class="album-cover">
                                            <div class="album-play-btn shadow-lg"><i class="fa-solid fa-play"></i></div>
                                        </div>
                                        <div class="album-title text-truncate">@album.Title</div>
                                        <div class="album-meta mt-1">@album.ReleaseYear • @album.AlbumType</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }

                <!-- C. MUSIC VIDEOS -->
                <section id="videos" class="mb-5 section-reveal">
                    <h3 class="section-title mb-4">Video âm nhạc</h3>
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                         @foreach (var song in Model.TopSongs.Take(4))
                         {
                             <div class="col">
                                 <div class="video-card group cursor-pointer" onclick="playSingleTrack('@song.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(song.Title)', '@System.Web.HttpUtility.JavaScriptStringEncode(Model.Name)', '@song.ThumbnailUrl')">
                                     <div class="video-thumb-wrapper overflow-hidden rounded-4 mb-3">
                                         <img src="https://img.youtube.com/vi/@song.YoutubeVideoId/maxresdefault.jpg" 
                                              onerror="this.src='@song.ThumbnailUrl'" class="w-100 transition-all group-hover-scale-110">
                                         <div class="video-duration">@(song.Duration.HasValue ? TimeSpan.FromSeconds(song.Duration.Value).ToString(@"m\:ss") : "--:--")</div>
                                         <div class="video-play-overlay"><i class="fa-solid fa-play display-4"></i></div>
                                     </div>
                                     <div class="fw-bold text-white text-truncate">@song.Title</div>
                                 </div>
                             </div>
                         }
                    </div>
                </section>
            </div>

            <!-- RIGHT SIDEBAR: Related Artists & Fans Also Like -->
            <div class="col-lg-4">
                <div class="sticky-sidebar" style="top: 100px;">
                    <!-- ARTIST PICK -->
                    <div class="glass-card p-4 rounded-5 mb-5 border-0 shadow-lg border-white border-opacity-10">
                        <h6 class="text-accent fw-bold uppercase small mb-3">Lựa chọn của nghệ sĩ</h6>
                        <div class="d-flex gap-3 align-items-center mb-4">
                            <img src="@(Model.TopSongs.FirstOrDefault()?.ThumbnailUrl)" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;">
                            <div>
                                <div class="white-space-nowrap fw-bold text-white small">Ngôi sao cô đơn</div>
                                <div class="extra-small text-dim">Nghe ngay bài hát mới nhất</div>
                            </div>
                        </div>
                        <button class="btn btn-outline-light w-100 rounded-pill btn-sm fw-bold">Xem thông báo</button>
                    </div>

                    <!-- BIO PREVIEW -->
                    <section id="about" class="mb-5 section-reveal">
                        <div class="about-card rounded-5 overflow-hidden relative cursor-pointer group" onclick="showFullBio()">
                            <img src="@(Model.BannerUrl ?? Model.AvatarUrl)" class="about-bg">
                            <div class="about-overlay p-4 d-flex flex-column justify-content-end">
                                <h3 class="fw-bold text-white mb-3">Giới thiệu</h3>
                                <div class="about-preview line-clamp-3 text-white-50 small mb-0">
                                    @Model.Bio
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- FANS ALSO LIKE -->
                    @if (Model.RelatedArtists.Any())
                    {
                        <div class="mb-5 section-reveal">
                            <h3 class="section-title-sm mb-4">Fan cũng yêu thích</h3>
                            <div class="d-flex flex-column gap-3">
                                @foreach (var ra in Model.RelatedArtists)
                                {
                                    <div class="d-flex align-items-center gap-3 p-2 rounded-4 hover-bg-light hover-bg-opacity-5 cursor-pointer group" 
                                         onclick="window.location.href='/Artist/Details/@ra.ArtistId'">
                                        <img src="@ra.AvatarUrl" class="rounded-circle shadow" style="width: 56px; height: 56px; object-fit: cover;">
                                        <div class="flex-grow-1">
                                            <div class="fw-bold text-white small group-hover-text-accent transition-all">@ra.Name</div>
                                            <div class="extra-small text-dim">@ra.MonthlyListeners Nghệ sĩ</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bio Modal -->
<div class="modal fade" id="bioModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass-card border-0 rounded-5 overflow-hidden">
            <div class="modal-body p-5">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <h2 class="fw-black text-white">Về @Model.Name</h2>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="bio-content text-white-50" style="font-size: 1.1rem; line-height: 2;">
                    @Model.Bio
                </div>
                <div class="mt-5 pt-4 border-top border-white border-opacity-10 row">
                    <div class="col-md-4">
                        <div class="text-white-50 small mb-1 uppercase">Xếp hạng thế giới</div>
                        <div class="text-white fw-bold fs-4">#@(new Random().Next(1, 500))</div>
                    </div>
                     <div class="col-md-4">
                        <div class="text-white-50 small mb-1 uppercase">Quốc gia</div>
                        <div class="text-white fw-bold fs-4">@Model.Country</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function playArtistTopTracks(artistId) {
            try {
                const res = await fetch(`/Home/GetArtistSongs?artistId=${artistId}`);
                const songs = await res.json();
                if (songs && songs.length > 0) {
                    playPlaylist(songs);
                }
            } catch(e) { console.error(e); }
        }

        async function toggleFollow(artistId) {
            const btn = document.getElementById('followBtn');
            try {
                const res = await fetch(`/Artist/ToggleFollow/${artistId}`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    if (data.isFollowing) {
                        btn.innerText = "Đang theo dõi";
                        btn.classList.add('following');
                    } else {
                        btn.innerText = "Theo dõi";
                        btn.classList.remove('following');
                    }
                } else if(res.status === 401) {
                    window.location.href = '/Auth/Login';
                }
            } catch (e) {}
        }

        async function toggleLikeByYoutubeId(youtubeId, btn) {
            try {
                const formData = new FormData();
                formData.append('youtubeId', youtubeId);
                const res = await fetch('/Interaction/ToggleLikeByYoutubeId', { method: 'POST', body: formData });
                const data = await res.json();
                if(data.success) {
                    if(data.isLiked) btn.classList.add('liked');
                    else btn.classList.remove('liked');
                }
            } catch(e) {}
        }

        function showFullBio() {
             const modal = new bootstrap.Modal(document.getElementById('bioModal'));
             modal.show();
        }

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.section-reveal').forEach(el => observer.observe(el));
    </script>
}

<style>
    .artist-header-hero { height: 500px; }
    .artist-banner-bg {
        position: absolute;
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        filter: brightness(0.7);
        z-index: 1;
    }
    .banner-gradient {
        position: absolute;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, transparent 0%, rgba(12,12,12,0.6) 60%, #0c0c0c 100%);
        z-index: 2;
    }
    .artist-avatar-main {
        width: 250px;
        height: 250px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }
    .artist-title-large { font-size: 80px; letter-spacing: -3px; }

    .btn-play-rounded {
        width: 64px;
        height: 64px;
        background: var(--accent-primary);
        color: black;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        border: none;
        transition: 0.2s;
    }
    .btn-play-rounded:hover { transform: scale(1.1); filter: brightness(1.1); }

    .btn-pill-filter {
        background: rgba(255,255,255,0.05);
        color: white;
        border: 0;
        padding: 6px 16px;
        border-radius: 8px;
        font-weight: 500;
        font-size: 14px;
        transition: 0.2s;
    }
    .btn-pill-filter.active { background: white; color: black; }

    /* SONG ROWS */
    .song-row-premium {
        display: grid;
        grid-template-columns: 40px 60px 1fr 120px 200px;
        align-items: center;
        padding: 12px 16px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.2s;
        gap: 15px;
    }
    .song-row-premium:hover { background: rgba(255,255,255,0.05); }
    .rank { font-weight: bold; color: #555; text-align: center; }
    .thumb-wrapper { position: relative; width: 50px; height: 50px; }
    .thumb-wrapper img { width: 100%; height: 100%; border-radius: 6px; object-fit: cover; }
    .play-icon { 
        position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.5); 
        display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.2s;
    }
    .song-row-premium:hover .play-icon { opacity: 1; }
    .song-title { font-weight: bold; color: white; }
    .plays, .duration { color: #888; font-size: 14px; }
    .actions { display: flex; align-items: center; gap: 15px; visibility: hidden; }
    .song-row-premium:hover .actions { visibility: visible; }
    .btn-icon { background: transparent; border: 0; color: #888; transition: 0.2s; }
    .btn-icon:hover { color: white; transform: scale(1.1); }
    .btn-icon.liked { color: #ff4757; }

    /* ALBUM CARDS */
    .album-card-pro .cover-wrapper { position: relative; aspect-ratio: 1/1; }
    .album-cover { width: 100%; height: 100%; border-radius: 12px; object-fit: cover; shadow-lg; }
    .album-play-btn {
        position: absolute; bottom: 15px; right: 15px; width: 50px; height: 50px;
        background: var(--accent-primary); color: black; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transform: translateY(10px); transition: 0.3s;
    }
    .album-card-pro:hover .album-play-btn { opacity: 1; transform: translateY(0); }
    .album-title { font-weight: bold; color: white; }
    .album-meta { font-size: 13px; color: #888; }

    /* VIDEO CARDS */
    .video-thumb-wrapper { position: relative; aspect-ratio: 16/9; }
    .video-duration { position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.8); color: white; padding: 2px 6px; border-radius: 4px; font-size: 12px; }
    .video-play-overlay { position: absolute; top:0; left:0; width:100%; height:100%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.4); opacity: 0; transition: 0.3s; }
    .video-card:hover .video-play-overlay { opacity: 1; }

    /* ABOUT SECTION */
    .about-card { height: 350px; box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
    .about-bg { position: absolute; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.6); }
    .about-overlay { position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(0deg, rgba(0,0,0,0.8) 0%, transparent 60%); }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

    .sticky-top-actions { top: 0; }
    .action-nav-link { color: #888; font-weight: bold; text-decoration: none; font-size: 14px; padding: 5px 0; border-bottom: 2px solid transparent; }
    .action-nav-link:hover, .action-nav-link.active { color: white; border-bottom-color: var(--accent-primary); }

    .dot-separator { width: 4px; height: 4px; background: #444; border-radius: 50%; }
    .btn.following { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2) !important; color: var(--accent-primary); }

    .section-reveal { opacity: 0; transform: translateY(30px); transition: 0.8s ease-out; }
    .section-reveal.revealed { opacity: 1; transform: translateY(0); }

    .badge-explicit { font-size: 9px; padding: 1px 4px; background: #333; border-radius: 2px; color: #888; display: inline-block; vertical-align: middle; }
</style>
