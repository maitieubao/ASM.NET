@model YoutubeMusicPlayer.Application.DTOs.ArtistDto
@{
    ViewData["Title"] = Model.Name + " - Nghệ sĩ";
}

<div class="artist-details-page animate-fade-in relative scrollbar-hide">
    <!-- 1. ARTIST HEADER (Modern Immersive Banner) -->
    <div class="artist-header-hero relative overflow-hidden">
        <div class="artist-banner-bg" style="background-image: url('@(Model.BannerUrl ?? Model.AvatarUrl ?? "https://images.unsplash.com/photo-1493225255756-d9584f8606e9?q=80&w=2000")');"></div>
        <div class="banner-gradient"></div>
        
        <div class="container relative z-10 pt-5 mt-5">
            <div class="d-flex align-items-end gap-md-5 gap-3 pb-5 flex-wrap flex-md-nowrap">
                <div class="artist-avatar-wrapper shadow-2xl">
                    <img src="@(Model.AvatarUrl ?? "https://ui-avatars.com/api/?name=" + Model.Name + "&size=300")" alt="@Model.Name" class="artist-avatar-main border border-white border-opacity-10">
                </div>
                <div class="mb-2 text-center text-md-start w-100">
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-2 text-accent mb-2 fw-bold small uppercase tracking-widest">
                        @if (Model.IsVerified)
                        {
                            <i class="fa-solid fa-circle-check fs-5"></i>
                        }
                        Nghệ sĩ đã xác minh
                    </div>
                    <h1 class="artist-title-large fw-black text-white m-0">@Model.Name</h1>
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-4 mt-3 text-white-50 fw-bold">
                        <span><i class="fa-solid fa-users me-2 text-accent"></i> @Model.MonthlyListeners người nghe hằng tháng</span>
                        <div class="dot-separator d-none d-md-block"></div>
                        <span>@Model.SubscriberCount.ToString("N0") người theo dõi</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. STICKY ACTION BAR -->
    <div class="sticky-top-actions glass-card backdrop-blur border-0 border-bottom border-white border-opacity-5 py-3 z-50">
        <div class="container d-flex align-items-center gap-4">
            <button class="btn-play-rounded shadow-accent" onclick="playArtistTopTracks(@Model.ArtistId)">
                <i class="fa-solid fa-play"></i>
            </button>
            <button id="followBtn" class="btn btn-outline-light rounded-pill px-4 fw-bold uppercase @(Model.IsFollowing ? "following" : "")" 
                    onclick="toggleFollow(@Model.ArtistId)">
                @(Model.IsFollowing ? "Đang theo dõi" : "Theo dõi")
            </button>
            <button class="btn btn-icon-circle text-white-50" title="Chia sẻ"><i class="fa-solid fa-share-nodes"></i></button>
            
            <div class="ms-auto d-none d-lg-flex align-items-center gap-4">
                <a href="#popular" class="action-nav-link active">Phổ biến</a>
                <a href="#discography" class="action-nav-link">Sự nghiệp</a>
                <a href="#videos" class="action-nav-link">Video</a>
                <a href="#about" class="action-nav-link">Giới thiệu</a>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-5">
            <!-- MAIN CONTENT -->
            <div class="col-lg-8">
                <!-- A. POPULAR SONGS -->
                <section id="popular" class="mb-5 section-reveal">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h3 class="section-title">Phổ biến</h3>
                        <button class="btn btn-link text-accent fw-bold text-decoration-none small">Bài hát hàng đầu</button>
                    </div>
                    <div class="popular-list">
                        @if (Model.TopSongs.Any())
                        {
                            @for (int i = 0; i < Model.TopSongs.Count(); i++)
                            {
                                var song = Model.TopSongs.ElementAt(i);
                                <div class="song-row-premium group" onclick="playSingleTrack('@song.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(song.Title)', '@System.Web.HttpUtility.JavaScriptStringEncode(Model.Name)', '@song.ThumbnailUrl')">
                                    <div class="rank text-dim">@(i + 1)</div>
                                    <div class="thumb-wrapper">
                                        <img src="@song.ThumbnailUrl" loading="lazy">
                                        <div class="play-icon"><i class="fa-solid fa-play text-white"></i></div>
                                    </div>
                                    <div class="title-meta">
                                        <div class="song-title text-truncate">
                                            @song.Title
                                            @if(song.IsExplicit){ <span class="badge-explicit">E</span> }
                                            @if(song.IsPremiumOnly){ <i class="fa-solid fa-gem text-accent ms-1" title="Premium Only"></i> }
                                        </div>
                                        <div class="text-dim extra-small d-md-none">@song.PlayCount.ToString("N0") lượt nghe</div>
                                    </div>
                                    <div class="plays d-none d-md-block">@song.PlayCount.ToString("N0")</div>
                                    <div class="actions">
                                        <button class="btn-icon" onclick="event.stopPropagation(); toggleLikeByYoutubeId('@song.YoutubeVideoId', this)">
                                            <i class="fa-solid fa-heart"></i>
                                        </button>
                                        <button class="btn-icon" title="Thêm vào Playlist" onclick="event.stopPropagation(); showAddToPlaylistModal('@song.YoutubeVideoId')">
                                            <i class="fa-solid fa-folder-plus text-accent"></i>
                                        </button>
                                        <div class="duration d-none d-sm-block">@(song.Duration.HasValue ? TimeSpan.FromSeconds(song.Duration.Value).ToString(@"m\:ss") : "--:--")</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </section>

                <!-- NEW: ALL SONGS PAGINATED -->
                <section id="all-songs" class="mb-5 section-reveal">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h4 class="fw-bold text-white m-0">Tất cả bài hát</h4>
                        <div class="text-dim extra-small">@Model.TotalSongsCount bài hát</div>
                    </div>
                    <div id="paginatedSongsContainer">
                         @foreach (var song in Model.PaginatedSongs) {
                            <div class="song-row-premium group" onclick="playSingleTrack('@song.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(song.Title)', '@System.Web.HttpUtility.JavaScriptStringEncode(Model.Name)', '@song.ThumbnailUrl')">
                                <div class="thumb-wrapper">
                                    <img src="@song.ThumbnailUrl" loading="lazy">
                                    <div class="play-icon"><i class="fa-solid fa-play text-white"></i></div>
                                </div>
                                <div class="title-meta">
                                    <div class="song-title text-truncate">@song.Title</div>
                                    <div class="text-dim extra-small">@Model.Name</div>
                                </div>
                                <div class="actions">
                                    <button class="btn-icon" onclick="event.stopPropagation(); showAddToPlaylistModal('@song.YoutubeVideoId')">
                                        <i class="fa-solid fa-plus extra-small"></i>
                                    </button>
                                    <div class="duration ms-3 text-dim extra-small">@(song.Duration.HasValue ? TimeSpan.FromSeconds(song.Duration.Value).ToString(@"m\:ss") : "--:--")</div>
                                </div>
                            </div>
                         }
                    </div>
                    
                    @if (Model.TotalPages > 1) {
                        <div class="d-flex justify-content-center mt-4 pt-3 border-top border-white border-opacity-5">
                            <div class="d-flex gap-2">
                                <a href="?page=@(Model.CurrentPage - 1)" class="btn btn-dark btn-sm rounded-pill px-3 @(Model.CurrentPage == 1 ? "disabled opacity-25" : "")">
                                    <i class="fa-solid fa-chevron-left me-1"></i> Trước
                                </a>
                                <span class="px-3 d-flex align-items-center text-dim small">Trang @Model.CurrentPage / @Model.TotalPages</span>
                                <a href="?page=@(Model.CurrentPage + 1)" class="btn btn-dark btn-sm rounded-pill px-3 @(Model.CurrentPage == Model.TotalPages ? "disabled opacity-25" : "")">
                                    Tiếp <i class="fa-solid fa-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    }
                </section>

                <!-- B. DISCOGRAPHY -->
                @if (Model.Albums.Any())
                {
                    <section id="discography" class="mb-5 section-reveal">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h3 class="section-title">Sự nghiệp (Discography)</h3>
                            <div class="d-flex gap-2">
                                <button class="btn-pill-filter active">Tất cả</button>
                                <button class="btn-pill-filter">Album</button>
                                <button class="btn-pill-filter">Single & EP</button>
                            </div>
                        </div>
                        <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-4">
                            @foreach (var album in Model.Albums)
                            {
                                <div class="col">
                                    <div class="music-card group" onclick="window.location.href='/Album/Details/@album.AlbumId'">
                                        <div class="card-thumb-wrapper mb-3">
                                            <img src="@(album.CoverImageUrl ?? "https://placehold.co/400x400/222/white?text=" + album.Title)" class="album-cover" loading="lazy">
                                            <div class="card-play-btn shadow-lg"><i class="fa-solid fa-play"></i></div>
                                        </div>
                                        <div class="card-title text-truncate">@album.Title</div>
                                        <div class="card-subtitle mt-1">@album.ReleaseYear • @album.AlbumType</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }

                <!-- C. MUSIC VIDEOS -->
                <section id="videos" class="mb-5 section-reveal">
                    <h3 class="section-title mb-4">Video âm nhạc</h3>
                    <div class="row g-4">
                         @foreach (var song in Model.TopSongs.Take(2))
                         {
                             <div class="col-md-6">
                                 <div class="video-card group cursor-pointer" onclick="playSingleTrack('@song.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(song.Title)', '@System.Web.HttpUtility.JavaScriptStringEncode(Model.Name)', '@song.ThumbnailUrl')">
                                     <div class="video-thumb-wrapper overflow-hidden rounded-4 mb-3 position-relative shadow-lg">
                                         <img src="https://img.youtube.com/vi/@song.YoutubeVideoId/maxresdefault.jpg" 
                                              onerror="this.src='@song.ThumbnailUrl'" class="w-100 transition-all group-hover-scale-110">
                                         <div class="video-duration">@(song.Duration.HasValue ? TimeSpan.FromSeconds(song.Duration.Value).ToString(@"m\:ss") : "--:--")</div>
                                         <div class="video-play-overlay"><i class="fa-solid fa-play display-4"></i></div>
                                     </div>
                                     <div class="fw-bold text-white text-truncate px-1">@song.Title</div>
                                     <div class="text-dim small px-1">Video âm nhạc chính thức</div>
                                 </div>
                             </div>
                         }
                    </div>
                </section>
            </div>

            <!-- SIDEBAR -->
            <div class="col-lg-4">
                <div class="sticky-sidebar">
                    <!-- BIO CARD -->
                    <section id="about" class="mb-5 section-reveal">
                        <div class="about-card rounded-5 overflow-hidden relative cursor-pointer group shadow-2xl" onclick="showFullBio()">
                            <img src="@(Model.BannerUrl ?? Model.AvatarUrl ?? "https://images.unsplash.com/photo-1493225255756-d9584f8606e9?q=80&w=2000")" class="about-bg transition-all group-hover-scale-110">
                            <div class="about-overlay p-4 d-flex flex-column justify-content-end">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h3 class="fw-bold text-white mb-0">Giới thiệu</h3>
                                    @if(!string.IsNullOrEmpty(Model.WikipediaUrl)) {
                                        <a href="@Model.WikipediaUrl" target="_blank" onclick="event.stopPropagation()" class="text-white-50 hover-text-white transition-all">
                                            <i class="fa-brands fa-wikipedia-w"></i>
                                        </a>
                                    }
                                </div>
                                <div class="about-preview line-clamp-4 text-white-50 small mb-0 lh-base">
                                    @Html.Raw(Model.Bio?.Replace("\n", "<br/>") ?? "Thông tin nghệ sĩ đang được cập nhật...")
                                </div>
                                <div class="mt-3 text-white fw-bold small">Xem thêm bài viết <i class="fa-solid fa-chevron-right ms-1 extra-small"></i></div>
                            </div>
                        </div>
                    </section>

                    <!-- RELATED ARTISTS -->
                    @if (Model.RelatedArtists.Any())
                    {
                        <div class="mb-5 section-reveal">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <h4 class="fw-bold text-white m-0">Fan cũng yêu thích</h4>
                                <button class="btn btn-link text-dim p-0"><i class="fa-solid fa-arrow-rotate-right small"></i></button>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                @foreach (var ra in Model.RelatedArtists.Take(5))
                                {
                                    <div class="d-flex align-items-center gap-3 p-3 rounded-4 hover-bg-light hover-bg-opacity-5 cursor-pointer group transition-all" 
                                         onclick="window.location.href='/Artist/Details/@ra.ArtistId'">
                                        <div class="position-relative">
                                            <img src="@ra.AvatarUrl" alt="@ra.Name" class="rounded-circle shadow" style="width: 56px; height: 56px; object-fit: cover;">
                                            @if(ra.IsVerified) {
                                                <i class="fa-solid fa-circle-check position-absolute bottom-0 end-0 text-accent bg-dark rounded-circle border border-dark" style="font-size: 14px;"></i>
                                            }
                                        </div>
                                        <div class="flex-grow-1 min-width-0">
                                            <div class="fw-bold text-white small group-hover-text-accent transition-all text-truncate">@ra.Name</div>
                                            <div class="extra-small text-dim">Nghệ sĩ</div>
                                        </div>
                                        <i class="fa-solid fa-chevron-right text-muted extra-small opacity-0 group-hover-opacity-100 transition-all"></i>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- BIO MODAL -->
<div class="modal fade" id="bioModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass-card border-white border-opacity-10 rounded-5 overflow-hidden shadow-2xl">
            <div class="modal-body p-0">
                <div class="bio-modal-header relative" style="height: 300px;">
                    <img src="@(Model.BannerUrl ?? Model.AvatarUrl)" class="w-100 h-100 object-fit-cover filter-brightness-50">
                    <div class="absolute inset-0 d-flex align-items-end p-5">
                       <h2 class="display-4 fw-black text-white m-0">Về @Model.Name</h2>
                    </div>
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4" data-bs-dismiss="modal"></button>
                </div>
                <div class="p-5">
                    <div class="bio-content text-white-50" style="font-size: 1.1rem; line-height: 1.8;">
                        @Html.Raw(Model.Bio?.Replace("\n", "<br/>") ?? "Thông tin nghệ sĩ đang được cập nhật...")
                    </div>
                    @if(!string.IsNullOrEmpty(Model.WikipediaUrl)) {
                        <div class="mt-3">
                            <a href="@Model.WikipediaUrl" target="_blank" class="btn btn-outline-light btn-sm rounded-pill px-4">
                                <i class="fa-brands fa-wikipedia-w me-2"></i> Đọc thêm trên Wikipedia
                            </a>
                        </div>
                    }
                    <div class="mt-5 pt-4 border-top border-white border-opacity-10 row g-4">
                        <div class="col-6 col-md-3">
                            <div class="text-white-50 small mb-1 uppercase tracking-tighter">Xếp hạng thế giới</div>
                            <div class="text-white fw-bold fs-4">#@(new Random().Next(1, 500))</div>
                        </div>
                         <div class="col-6 col-md-3">
                            <div class="text-white-50 small mb-1 uppercase tracking-tighter">Quốc gia</div>
                            <div class="text-white fw-bold fs-4">@Model.Country</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-white-50 small mb-1 uppercase tracking-tighter">Người theo dõi</div>
                            <div class="text-white fw-bold fs-4">@Model.SubscriberCount.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="page-title-data" value="@Model.Name - Nghệ sĩ" />

<script>
    (function() {
        console.log("[Artist] Initializing view...");
        
        // Define localized functions for this view
        window.playArtistTopTracks = async function(artistId) {
            try {
                const res = await fetch(`/Home/GetArtistSongs?artistId=${artistId}`);
                const songs = await res.json();
                if (songs && songs.length > 0) {
                    playPlaylist(songs);
                }
            } catch(e) { console.error(e); }
        };

        window.toggleFollow = async function(artistId) {
            const btn = document.getElementById('followBtn');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            
            try {
                const res = await fetch(`/Artist/ToggleFollow/${artistId}`, { 
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token || '' }
                });
                const json = await res.json();
                const data = json.data || json;
                
                if (json.success || json.Success || data.success) {
                    const isFollowing = data.isFollowing !== undefined ? data.isFollowing : data.data.isFollowing;
                    if (isFollowing) {
                        btn.innerText = "Đang theo dõi";
                        btn.classList.add('following');
                        if(typeof toastr !== 'undefined') toastr.success("Đã theo dõi nghệ sĩ!");
                    } else {
                        btn.innerText = "Theo dõi";
                        btn.classList.remove('following');
                        if(typeof toastr !== 'undefined') toastr.info("Đã bỏ theo dõi.");
                    }
                } else if(res.status === 401) {
                    if (window.SPARouter) window.SPARouter.navigateTo('/Auth/Login');
                    else window.location.href = '/Auth/Login';
                }
            } catch (e) {
                console.error('[Artist] Follow error:', e);
            }
        };

        window.toggleLikeByYoutubeId = async function(youtubeId, btn) {
            try {
                const formData = new FormData();
                formData.append('youtubeId', youtubeId);
                const res = await fetch('/Interaction/ToggleLikeByYoutubeId', { method: 'POST', body: formData });
                const data = await res.json();
                if(data.success) {
                    if(data.isLiked) btn.classList.add('liked');
                    else btn.classList.remove('liked');
                }
            } catch(e) {}
        };

        window.showFullBio = function() {
             const $modal = $('#bioModal');
             if ($modal.length) {
                const modal = new bootstrap.Modal($modal[0]);
                modal.show();
             }
        };

        // Scroll reveal logic
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.section-reveal').forEach(el => observer.observe(el));
    })();
</script>

