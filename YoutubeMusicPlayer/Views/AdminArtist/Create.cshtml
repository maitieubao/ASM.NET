@model YoutubeMusicPlayer.Application.DTOs.ArtistDto
@{
    ViewData["Title"] = "Thêm nghệ sĩ mới";
}

<div class="container mt-4 pb-5 text-white animate-fade-in">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-black m-0">Thêm nghệ sĩ mới</h2>
            <div class="text-dim small">Nhập thông tin hồ sơ nghệ sĩ vào hệ thống</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Hủy bỏ</a>
            <button type="submit" form="artistForm" class="btn btn-warning rounded-pill px-5 fw-bold">Tạo hồ sơ</button>
        </div>
    </div>

    <div class="row g-5">
        <!-- Preview Sidebar -->
        <div class="col-lg-4">
            <div class="glass-card p-4 rounded-5 border-0 shadow-lg text-center mb-4 sticky-sidebar" style="top: 100px;">
                <div class="position-relative mb-4 group">
                    <img id="avatarPreview" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://placehold.co/600x600/111/444?text=Avatar" : Model.AvatarUrl)" 
                         class="w-100 rounded-pill shadow-2xl transition-all" style="aspect-ratio: 1; object-fit: cover; border: 4px solid rgba(255,255,255,0.1);">
                </div>
                <h4 id="namePreview" class="fw-bold text-white mb-1">@(string.IsNullOrEmpty(Model.Name) ? "Tên nghệ sĩ" : Model.Name)</h4>
                <div class="text-dim small mb-4">Mã định danh: Dự kiến tạo tự động</div>
                
                <div class="mt-4 pt-4 border-top border-white border-opacity-10 text-start">
                    <div class="text-dim uppercase small fw-bold mb-3">Yêu cầu hồ sơ</div>
                    <ul class="extra-small text-white-50 ps-3">
                        <li class="mb-2">Tên nghệ sĩ không được để trống.</li>
                        <li class="mb-2">Avatar nên là hình vuông (tỷ lệ 1:1).</li>
                        <li>Trạng thái "Verified" có thể cấp sau sau khi xác minh.</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Form -->
        <div class="col-lg-8">
            <form id="artistForm" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="glass-card rounded-5 border-0 p-5 shadow-2xl">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label x-small uppercase fw-bold text-dim">Tên nghệ sĩ</label>
                            <input asp-for="Name" class="form-control-pro" placeholder="Nhập tên nghệ sĩ..." required oninput="document.getElementById('namePreview').innerText = this.value || 'Tên nghệ sĩ'" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label x-small uppercase fw-bold text-dim">Quốc gia</label>
                            <input asp-for="Country" class="form-control-pro" placeholder="e.g. Việt Nam, USA" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label x-small uppercase fw-bold text-dim">Avatar URL</label>
                            <input asp-for="AvatarUrl" class="form-control-pro" placeholder="https://..." oninput="document.getElementById('avatarPreview').src = this.value || 'https://placehold.co/600x600/111/444?text=Avatar'" />
                        </div>

                        <div class="col-12">
                            <label class="form-label x-small uppercase fw-bold text-dim">Ảnh bìa (Banner URL)</label>
                            <input asp-for="BannerUrl" class="form-control-pro" placeholder="https://..." />
                        </div>

                        <div class="col-12">
                            <label class="form-label x-small uppercase fw-bold text-dim">Tiểu sử (Bio)</label>
                            <textarea asp-for="Bio" class="form-control-pro" rows="5" placeholder="Nhập tiểu sử nghệ sĩ..."></textarea>
                        </div>

                        <div class="col-md-6 mt-5">
                            <div class="config-card glass-card p-4 rounded-4 border-0">
                                <h6 class="fw-bold mb-3">Trạng thái xác minh</h6>
                                <div class="form-check form-switch p-0 m-0 d-flex align-items-center gap-3">
                                    <input class="form-check-input ms-0 cursor-pointer" type="checkbox" role="switch" asp-for="IsVerified">
                                    <label class="form-check-label small" asp-for="IsVerified">Nghệ sĩ đã xác minh (Verified)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control-pro { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; color: white; padding: 12px 18px; width: 100%; transition: 0.2s; }
    .form-control-pro:focus { background: rgba(255,255,255,0.08); border-color: #ffc107; outline: none; }
    
    .custom-check .form-check-input { background-color: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.2); }
    .custom-check .form-check-input:checked { background-color: #ffc107; border-color: #ffc107; }
</style>
