@model YoutubeMusicPlayer.Application.DTOs.UserProfileViewModel
@{
    ViewData["Title"] = "Trang cá nhân - " + Model.User.Username;
    var history = Model.ListeningHistory ?? new List<YoutubeMusicPlayer.Application.DTOs.ListeningHistoryDto>();
    var notifications = Model.Notifications ?? new List<YoutubeMusicPlayer.Application.DTOs.NotificationDto>();
    var playlists = Model.Playlists ?? new List<YoutubeMusicPlayer.Application.DTOs.PlaylistDto>();
    var topGenres = Model.TopGenres ?? new List<string>();
    int unreadCount = notifications.Any() ? notifications.Count(n => !n.IsRead) : 0;
}

<div class="user-profile-page animate-fade-in scrollbar-hide">
    <!-- 1. PROFILE HEADER -->
    <div class="profile-header relative overflow-hidden py-5 mb-5">
        <div class="profile-bg-blur" style="background-image: url('@(Model.User.AvatarUrl ?? "https://ui-avatars.com/api/?name=" + Model.User.Username + "&background=6C5CE7&color=fff&size=512")')"></div>
        
        <div class="container relative z-10">
            <div class="d-flex align-items-center gap-md-5 gap-3 flex-wrap flex-md-nowrap">
                <div class="profile-avatar-wrapper shadow-2xl">
                    <img src="@(Model.User.AvatarUrl ?? "https://ui-avatars.com/api/?name=" + Model.User.Username + "&size=300")" alt="@Model.User.Username" class="profile-avatar-main border border-white border-opacity-10">
                    <div class="avatar-edit-overlay"><i class="fa-solid fa-camera"></i></div>
                </div>
                <div class="profile-info-main text-center text-md-start w-100">
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-2 mb-3">
                        <span class="badge bg-accent text-white rounded-pill px-3 py-1 small fw-bold uppercase tracking-widest">@Model.User.Role</span>
                        @if(Model.User.IsPremium)
                        {
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-1 small fw-bold uppercase tracking-widest">Premium Member</span>
                        }
                    </div>
                    <h1 class="profile-username fw-black text-white m-0">@Model.User.Username</h1>
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-4 mt-3 text-white-50 fw-bold">
                        <span><i class="fa-solid fa-layer-group me-2 text-accent"></i> @playlists.Count() Playlist</span>
                        <div class="dot-separator d-none d-md-block"></div>
                        <span><i class="fa-solid fa-clock me-2 text-warning"></i> Tham gia @Model.User.CreatedAt.ToString("MM/yyyy")</span>
                    </div>
                    <div class="mt-4 d-flex justify-content-center justify-content-md-start gap-3">
                        <a asp-action="Edit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-accent">
                            <i class="fa-solid fa-pen-to-square me-2"></i> Chỉnh sửa hồ sơ
                        </a>
                        <button class="btn btn-outline-light btn-icon-circle" title="Cài đặt"><i class="fa-solid fa-gear"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-4">
        <!-- 2. QUICK STATS -->
        <div class="row g-4 mb-5 section-reveal">
            <div class="col-6 col-md-3">
                <div class="stat-card glass-card p-4 rounded-5 border-white border-opacity-5 text-center transition-all hover-translate-y">
                    <div class="stat-icon mb-2 text-accent"><i class="fa-solid fa-play fs-3"></i></div>
                    <div class="stat-value fw-black text-white fs-3">@history.Count().ToString("N0")</div>
                    <div class="stat-label text-white-50 extra-small uppercase">Bài hát đã nghe</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card glass-card p-4 rounded-5 border-white border-opacity-5 text-center transition-all hover-translate-y">
                    <div class="stat-icon mb-2 text-danger"><i class="fa-solid fa-heart fs-3"></i></div>
                    <div class="stat-value fw-black text-white fs-3">@Model.LikedSongsCount.ToString("N0")</div>
                    <div class="stat-label text-white-50 extra-small uppercase">Yêu thích</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card glass-card p-4 rounded-5 border-white border-opacity-5 text-center transition-all hover-translate-y">
                    <div class="stat-icon mb-2 text-accent"><i class="fa-solid fa-compact-disc fs-3"></i></div>
                    <div class="stat-value fw-black text-white fs-3">@playlists.Count()</div>
                    <div class="stat-label text-white-50 extra-small uppercase">Danh sách phát</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card glass-card p-4 rounded-5 border-white border-opacity-5 text-center transition-all hover-translate-y">
                    <div class="stat-icon mb-2 text-info"><i class="fa-solid fa-clock fs-3"></i></div>
                    <div class="stat-value fw-black text-white fs-3">@Math.Round(Model.TotalListenTimeMinutes, 0).ToString("N0")</div>
                    <div class="stat-label text-white-50 extra-small uppercase">Phút nghe nhạc</div>
                </div>
            </div>
        </div>

        <!-- 3. FOLLOWED ARTISTS SECTION -->
        <section class="mb-5 section-reveal">
            <h3 class="section-title mb-4">Nghệ sĩ đang quan tâm</h3>
            <div class="d-flex gap-4 overflow-auto pb-3 scrollbar-hide">
                @if (Model.FollowedArtists != null && Model.FollowedArtists.Any())
                {
                    foreach (var artist in Model.FollowedArtists)
                    {
                        <div class="artist-card-mini group text-center" style="min-width: 120px; cursor: pointer;" onclick="window.location.href='/Artist/Details/@artist.ArtistId'">
                            <div class="avatar-wrapper mx-auto mb-3 overflow-hidden rounded-circle bg-white bg-opacity-10 border border-white border-opacity-20">
                                <img src="@(string.IsNullOrEmpty(artist.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + artist.Name + "&size=200" : artist.AvatarUrl)" alt="@artist.Name" class="w-100 h-100 object-fit-cover group-hover-scale-110">
                            </div>
                            <h6 class="text-white fw-bold m-0 text-truncate">@artist.Name</h6>
                            <span class="text-white-50 extra-small">Nghệ sĩ</span>
                        </div>
                    }
                }
                else
                {
                    <div class="glass-card p-4 w-100 text-center text-white-50 rounded-4 border border-white border-opacity-5">
                        <i class="fa-solid fa-users-slash d-block mb-2 opacity-50 fs-4"></i>
                        Bạn chưa theo dõi nghệ sĩ nào.
                    </div>
                }
            </div>
        </section>

        <div class="row g-5">
            <div class="col-lg-8">
                <!-- A. MY PLAYLISTS -->
                <section class="mb-5 section-reveal">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h3 class="section-title">Playlist của tôi</h3>
                        <a asp-controller="Playlist" asp-action="Index" class="btn btn-accent btn-sm rounded-pill px-3 fw-bold shadow-lg shadow-accent/20">
                            <i class="fa-solid fa-plus me-1"></i> Quản lý
                        </a>
                    </div>
                    @if (playlists.Any())
                    {
                        <div class="row row-cols-2 row-cols-md-3 g-4">
                            @foreach (var pl in playlists)
                            {
                                <div class="col">
                                    <div class="music-card group shadow-lg" onclick="window.location.href='/Playlist/Details/@pl.PlaylistId'">
                                        <div class="card-thumb-wrapper mb-3">
                                            <img src="@(string.IsNullOrEmpty(pl.CoverImageUrl) ? "https://ui-avatars.com/api/?name=" + pl.Title + "&background=282828&color=fff&size=400" : pl.CoverImageUrl)" class="playlist-thumb" loading="lazy">
                                            <div class="card-play-btn shadow-accent" onclick="event.stopPropagation(); playPlaylist(@pl.PlaylistId)"><i class="fa-solid fa-play"></i></div>
                                        </div>
                                        <h6 class="text-white fw-bold text-truncate mb-1">@pl.Title</h6>
                                        <span class="text-white-50 extra-small">@(pl.IsPublic ? "Công khai" : "Riêng tư")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="glass-card p-5 text-center text-white-50 rounded-5 border border-white border-opacity-5">
                             <p>Hãy tạo playlist đầu tiên của bạn để lưu giữ những bài hát yêu thích!</p>
                             <a href="/Playlist/Create" class="btn btn-outline-accent btn-sm rounded-pill px-4 mt-2">Tạo ngay</a>
                        </div>
                    }
                </section>

                <!-- B. RECENTLY PLAYED -->
                <section class="mb-5 section-reveal">
                    <h3 class="section-title mb-4">Nghe gần đây</h3>
                    <div class="glass-card rounded-5 overflow-hidden">
                        @if (history.Any())
                        {
                            foreach (var h in history.Take(5))
                            {
                                <div class="song-row-premium" onclick="playSong(@h.SongId)">
                                    <div class="thumb-wrapper">
                                        <img src="@h.ThumbnailUrl" loading="lazy">
                                        <div class="play-icon"><i class="fa-solid fa-play text-white"></i></div>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <h6 class="text-white fw-bold m-0 text-truncate">@h.SongTitle</h6>
                                        <span class="text-white-50 extra-small">@h.AuthorName</span>
                                    </div>
                                    <div class="text-white-50 extra-small">@h.ListenedAt.ToString("HH:mm dd/MM")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-5 text-center text-white-50">Lịch sử nghe nhạc đang trống.</div>
                        }
                    </div>
                </section>
            </div>

            <div class="col-lg-4">
                <div class="sticky-sidebar">
                    <!-- C. DISCOVER GENRES -->
                    <section class="mb-5 section-reveal">
                         <h3 class="section-title mb-4">Gu âm nhạc</h3>
                        <div class="glass-card p-4 rounded-5 border border-white border-opacity-5">
                            @if (topGenres.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var g in topGenres)
                                    {
                                        <span class="badge bg-white bg-opacity-10 text-white rounded-pill px-3 py-2 fw-medium border border-white border-opacity-5">#@g</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-white-50 small">Hãy nghe nhạc nhiều hơn để khám phá gu âm nhạc của bạn!</div>
                            }
                        </div>
                    </section>

                    <!-- D. NOTIFICATIONS -->
                    <section class="mb-5 section-reveal">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h3 class="section-title">Thông báo</h3>
                            @if(unreadCount > 0)
                            {
                                <span class="badge bg-danger rounded-pill shadow-lg shadow-danger/20">@unreadCount mới</span>
                            }
                        </div>
                        <div class="glass-card rounded-5 overflow-hidden border border-white border-opacity-5">
                            @if(notifications.Any())
                            {
                                foreach(var n in notifications.Take(4))
                                {
                                    <div class="notif-row p-4 border-bottom border-white border-opacity-5 d-flex gap-4 @(!n.IsRead ? "active-notif" : "opacity-75")" 
                                         id="notif-@n.NotificationId" 
                                         onclick="markRead(@n.NotificationId)">
                                        <div class="notif-type-icon @(n.Type == "System" ? "text-info" : "text-warning")">
                                            <i class="fa-solid @(n.Type == "System" ? "fa-circle-info" : "fa-star") fs-4"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-start mb-1">
                                                <h6 class="fw-bold text-white m-0">@n.Title</h6>
                                                <span class="text-white-50 extra-small">@n.CreatedAt.ToString("dd/MM")</span>
                                            </div>
                                            <p class="text-white-50 small m-0">@n.Message</p>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="p-5 text-center text-white-50 small">
                                    <i class="fa-solid fa-bell-slash d-block mb-2 fs-3 opacity-20"></i>
                                    Bạn chưa có thông báo mới nào.
                                </div>
                            }
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function markRead(id) {
            const el = document.getElementById('notif-' + id);
            if (!el || !el.classList.contains('active-notif')) return;

            // Optimistic UI update: immediate visual feedback
            el.classList.remove('active-notif');
            el.classList.add('opacity-75');
            
            try {
                // CSRF Token is required for POST requests
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const headers = { 'Content-Type': 'application/json' };
                if (token) headers['RequestVerificationToken'] = token;

                const res = await fetch('/User/MarkNotificationRead/' + id, { 
                    method: 'POST',
                    headers: headers
                });
                
                if(!res.ok) {
                    // Rollback if server fails
                    el.classList.add('active-notif');
                    el.classList.remove('opacity-75');
                }
            } catch(e) {
                console.error('[Notification] MarkRead error:', e);
            }
        }

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.section-reveal').forEach(el => observer.observe(el));
    </script>
}

<style>
    .user-profile-page { min-height: 100vh; }
    .z-10 { z-index: 10 !important; }
    .profile-header { min-height: 350px; position: relative; }
    .profile-bg-blur {
        position: absolute; inset: 0;
        background-size: cover; background-position: center;
        filter: blur(80px) brightness(0.4); opacity: 0.4; z-index: 1;
    }
    .profile-avatar-wrapper { position: relative; width: 180px; height: 180px; flex-shrink: 0; }
    .profile-avatar-main { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
    .avatar-edit-overlay {
        position: absolute; bottom: 10px; right: 10px; width: 44px; height: 44px;
        background: white; color: black; border-radius: 50%; display: flex;
        align-items: center; justify-content: center; font-size: 1.2rem;
        cursor: pointer; opacity: 0; transition: 0.3s;
    }
    .profile-avatar-wrapper:hover .avatar-edit-overlay { opacity: 1; }
    
    .profile-username { font-size: 4rem; letter-spacing: -2px; }
    @@media (max-width: 768px) {
        .profile-username { font-size: 2.5rem; letter-spacing: -1px; }
        .profile-avatar-wrapper { width: 140px; height: 140px; }
    }

    .hover-translate-y:hover { transform: translateY(-5px); }
    .stat-label { letter-spacing: 0.05em; margin-top: 4px; }
    .playlist-thumb { width: 100%; aspect-ratio: 1; border-radius: 16px; object-fit: cover; }
    .section-reveal { opacity: 0; transform: translateY(30px); transition: 0.8s ease-out; }
    .section-reveal.revealed { opacity: 1; transform: translateY(0); }
    .sticky-sidebar { position: sticky; top: 100px; }

    .song-row-premium {
        display: flex; align-items: center; gap: 16px;
        padding: 12px; border-radius: 12px; cursor: pointer; transition: 0.2s;
    }
    .song-row-premium:hover { background: rgba(255,255,255,0.08); }
    .thumb-wrapper { width: 48px; height: 48px; flex-shrink: 0; position: relative; }
    .thumb-wrapper img { width: 100%; height: 100%; border-radius: 8px; object-fit: cover; }
    .play-icon { 
        position: absolute; inset: 0; background: rgba(0,0,0,0.5); 
        display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.2s;
        border-radius: 8px;
    }
    .song-row-premium:hover .play-icon { opacity: 1; }

    .avatar-wrapper { width: 80px; height: 80px; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .artist-card-mini:hover .avatar-wrapper { transform: scale(1.1); box-shadow: 0 10px 30px rgba(108, 92, 231, 0.4); }
    .group-hover-scale-110 { transition: 0.4s; }
    .artist-card-mini:hover .group-hover-scale-110 { transform: scale(1.1); }
    .notif-row { cursor: pointer; transition: 0.3s; }
    .notif-row:hover { background: rgba(255,255,255,0.05); }
    .active-notif { background: rgba(108, 92, 231, 0.1) !important; border-left: 3px solid var(--accent-primary); }
    .opacity-75 { opacity: 0.75; }
</style>
