@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.ListeningHistoryDto>
@{
    ViewData["Title"] = "Listening History";
}

<div class="container mt-4 pb-5 text-white">
    <div class="mb-5">
        <h2 class="fw-bold"><i class="bi bi-clock-history me-3 text-accent"></i> My Listening History</h2>
        <p class="text-white-50">A log of all your musical journeys on MusicManager.</p>
    </div>

    <div class="card bg-dark-glass border-secondary border-opacity-25 shadow-lg overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4 align-middle">
                <thead class="bg-black bg-opacity-20 text-white-50">
                    <tr>
                        <th class="ps-4 py-3">#</th>
                        <th>Song Title</th>
                        <th>Artist</th>
                        <th>Listen Time</th>
                        <th class="text-end pe-4">Play Again</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var h in Model.OrderByDescending(x => x.ListenedAt))
                    {
                        <tr>
                            <td class="ps-4 text-white-50">@i</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@h.ThumbnailUrl" class="rounded me-3 shadow-sm" style="width: 40px; height: 40px; object-fit: cover;">
                                    <div class="fw-bold">@h.SongTitle</div>
                                </div>
                            </td>
                            <td class="text-white-50">@h.AuthorName</td>
                            <td class="small opacity-75">@h.ListenedAt.ToString("f")</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-accent rounded-circle" 
                                        onclick="playSingleTrack('@h.YoutubeVideoId', '@System.Web.HttpUtility.JavaScriptStringEncode(h.SongTitle)', '@System.Web.HttpUtility.JavaScriptStringEncode(h.AuthorName)', '@h.ThumbnailUrl')">
                                    <i class="bi bi-play-fill fs-5"></i>
                                </button>
                            </td>
                        </tr>
                        i++;
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-white-50">No history found. Go explore some music!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-dark-glass { background: rgba(20,20,20,0.8); backdrop-filter: blur(15px); }
    .btn-outline-accent { border-color: var(--accent-color); color: var(--accent-color); }
    .btn-outline-accent:hover { background: var(--accent-color); color: white; }
</style>
