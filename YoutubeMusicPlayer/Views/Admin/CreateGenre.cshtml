@model YoutubeMusicPlayer.Application.DTOs.GenreDto
@{
    ViewData["Title"] = "Create Genre";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <a asp-action="Genres" class="btn btn-outline-secondary btn-sm mb-3">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
                <h2 class="text-white fw-bold"><i class="bi bi-plus-circle-fill me-2 text-accent"></i> New Genre</h2>
            </div>

            <div class="card bg-dark-glass text-white border-secondary border-opacity-25 shadow-lg p-3">
                <div class="card-body">
                    <form asp-action="CreateGenre" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label text-white-50 small">Genre Name</label>
                            <input asp-for="Name" class="form-control bg-dark text-white border-secondary" placeholder="Pop, Rock, EDM, etc...">
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label text-white-50 small">Genre Info</label>
                            <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="3" placeholder="Brief history or characteristics of this genre..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary rounded-pill py-2">
                                <i class="bi bi-music-note me-1"></i> Add Genre
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
