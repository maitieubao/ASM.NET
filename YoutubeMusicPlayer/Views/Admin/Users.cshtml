@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.UserDto>
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold"><i class="bi bi-people-fill me-2 text-accent"></i> User Management</h2>
        <form asp-action="Users" method="get" class="d-flex">
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control me-2 bg-dark text-white border-secondary" placeholder="Search by name or email...">
            <button type="submit" class="btn btn-outline-accent">Search</button>
        </form>
    </div>

    <div class="card bg-dark-glass text-white border-secondary border-opacity-25 shadow-lg">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4">
                <thead>
                    <tr class="text-white-50">
                        <th>ID</th>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Created At</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                    {
                                        <img src="@user.AvatarUrl" class="rounded-circle me-2" width="32" height="32" style="object-fit: cover;">
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-circle fs-5 me-2"></i>
                                    }
                                    <span>@user.Username</span>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">@user.Role</span>
                                @if(user.IsPremium)
                                {
                                    <span class="badge bg-warning text-dark ms-1"><i class="bi bi-gem"></i></span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <span class="badge bg-danger">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group">
                                    <a asp-action="UserDetails" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-action="ToggleUserLock" asp-route-id="@user.UserId" method="post" onsubmit="return confirm('Are you sure to toggle lock status for this user?')" class="d-inline">
                                        <button type="submit" class="btn btn-sm @(user.IsLocked ? "btn-outline-success" : "btn-outline-warning")" title="@(user.IsLocked ? "Unlock" : "Lock")">
                                            <i class="bi @(user.IsLocked ? "bi-unlock" : "bi-lock")"></i>
                                        </button>
                                    </form>
                                    @if (user.Role != "Admin")
                                    {
                                        <form asp-action="DeleteUser" asp-route-id="@user.UserId" method="post" onsubmit="return confirm('Are you sure to delete this user? This action cannot be undone.')" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
