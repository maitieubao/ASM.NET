@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.CommentDto>
@{
    ViewData["Title"] = "Comment Moderation";
}

<div class="container mt-4 pb-5 text-white">
    <div class="mb-5 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold"><i class="bi bi-chat-square-dots-fill me-2 text-info"></i> Comment Moderation</h2>
            <p class="text-white-50">Manage user interactions and ensure a safe community.</p>
        </div>
        <div class="text-end">
            <input type="text" id="comment-search" class="form-control bg-dark text-white border-secondary" placeholder="Search comments...">
        </div>
    </div>

    <div class="card bg-dark-glass border-secondary border-opacity-25 shadow-lg overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4 align-middle">
                <thead class="bg-black bg-opacity-20 text-white-50">
                    <tr>
                        <th class="ps-4 py-3">User</th>
                        <th>Comment Content</th>
                        <th>Target Song</th>
                        <th>Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="comment-list">
                    @foreach (var c in Model)
                    {
                        <tr class="comment-row">
                            <td class="ps-4">
                                <div class="fw-bold">@c.UserName</div>
                                <div class="text-white-50 small">ID: @c.UserId</div>
                            </td>
                            <td style="max-width: 400px;">
                                <div class="comment-content">@c.Content</div>
                            </td>
                            <td>
                                <div class="fw-bold text-info">@c.SongTitle</div>
                                <div class="text-white-50 small">ID: @c.SongId</div>
                            </td>
                            <td class="small">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <form asp-action="DeleteComment" asp-route-id="@c.CommentId" method="post" onsubmit="return confirm('Delete this comment?')" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm">
                                        <i class="bi bi-trash-fill me-1"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.getElementById('comment-search').addEventListener('keyup', function() {
        var term = this.value.toLowerCase();
        var rows = document.querySelectorAll('.comment-row');
        rows.forEach(function(row) {
            var content = row.querySelector('.comment-content').textContent.toLowerCase();
            var user = row.querySelector('.fw-bold').textContent.toLowerCase();
            if(content.indexOf(term) > -1 || user.indexOf(term) > -1) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>

<style>
    .bg-dark-glass { background: rgba(25, 25, 25, 0.85); backdrop-filter: blur(15px); }
</style>
