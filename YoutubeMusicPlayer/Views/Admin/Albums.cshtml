@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.AlbumDto>
@{
    ViewData["Title"] = "Album Management";
}

<div class="container-fluid mt-4 pb-5 px-lg-5 text-white">
    <div class="mb-5 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold"><i class="bi bi-journal-album me-2 text-info"></i> Album Management</h2>
            <p class="text-white-50">Organize and manage music albums and Discography records.</p>
        </div>
        <div class="d-flex gap-3">
             <input type="text" id="album-search" class="form-control bg-dark text-white border-secondary" placeholder="Search albums..." style="width: 300px;">
        </div>
    </div>

    <div class="card bg-dark-glass border-secondary border-opacity-25 shadow-lg overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4 align-middle">
                <thead class="bg-black bg-opacity-20 text-white-50">
                    <tr>
                        <th class="ps-4 py-3">Album</th>
                        <th>Type</th>
                        <th>Release Date</th>
                        <th>Explicit</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="album-list">
                    @foreach (var a in Model)
                    {
                        <tr class="album-row">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(a.CoverImageUrl) ? "/images/default-album.png" : a.CoverImageUrl)" class="rounded me-3 shadow-sm" style="width: 50px; height: 50px; object-fit: cover; aspect-ratio: 1;">
                                    <div>
                                        <div class="fw-bold album-title">@a.Title</div>
                                        <div class="text-white-50 small">ID: @a.AlbumId</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-secondary">@a.AlbumType</span></td>
                            <td>@(a.ReleaseDate?.ToString("dd/MM/yyyy") ?? "--")</td>
                            <td>
                                @if (a.IsExplicit)
                                {
                                    <span class="badge bg-danger">EXPLICIT</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">CLEAN</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditAlbum" asp-route-id="@a.AlbumId" class="btn btn-sm btn-outline-info me-2">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="DeleteAlbum" asp-route-id="@a.AlbumId" method="post" class="d-inline" onsubmit="return confirm('Delete this album and unlink all songs?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-white-50">No albums found in the system.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.getElementById('album-search').addEventListener('keyup', function() {
        var term = this.value.toLowerCase();
        var rows = document.querySelectorAll('.album-row');
        rows.forEach(function(row) {
            var title = row.querySelector('.album-title').textContent.toLowerCase();
            if(title.indexOf(term) > -1) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>

<style>
    .bg-dark-glass { background: rgba(20, 20, 20, 0.85); backdrop-filter: blur(15px); }
</style>
