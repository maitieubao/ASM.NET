@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Category Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold"><i class="bi bi-folder-fill me-2 text-accent"></i> Categories</h2>
        <a asp-action="CreateCategory" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-lg me-1"></i> Add Category
        </a>
    </div>

    <div class="card bg-dark-glass text-white border-secondary border-opacity-25 shadow-lg">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4 align-middle">
                <thead>
                    <tr class="text-white-50">
                        <th>ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Created At</th>
                        <th>Songs</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CategoryId</td>
                            <td class="fw-bold text-white">@item.Name</td>
                            <td class="text-white-50 small">@item.Description</td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-secondary border border-secondary border-opacity-50">
                                    @item.SongCount Songs
                                </span>
                            </td>
                            <td>
                                <div class="btn-group">
                                    <a asp-action="EditCategory" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="DeleteCategory" asp-route-id="@item.CategoryId" method="post" onsubmit="return confirm('Delete this category?')" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
