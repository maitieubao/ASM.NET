@model IEnumerable<YoutubeMusicPlayer.Application.DTOs.ReportDto>
@{
    ViewData["Title"] = "Reports Management";
}

<div class="container mt-4 pb-5">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="text-white fw-bold"><i class="bi bi-flag-fill me-2 text-danger"></i> User Reports</h2>
            <p class="text-white-50">Manage reports of content or user misconduct.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-danger rounded-pill px-3 py-2">
                @Model.Count(r => r.Status == "Pending") Pending
            </span>
        </div>
    </div>

    <div class="card bg-dark-glass text-white border-secondary border-opacity-25 shadow-lg">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 p-4 align-middle">
                <thead>
                    <tr class="text-white-50">
                        <th class="ps-4">Reporter</th>
                        <th>Target</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Reported At</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr class="@(r.Status == "Pending" ? "bg-opacity-10 bg-danger" : "opacity-75")">
                            <td class="ps-4">
                                <div class="fw-bold text-white">@r.UserName</div>
                                <div class="text-white-50 small">ID: @r.UserId</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary mb-1">@r.TargetType</span>
                                <div class="fw-bold">@r.TargetName</div>
                                <div class="text-white-50 x-small">Target ID: @r.TargetId</div>
                            </td>
                            <td>
                                <div class="text-white">@r.Reason</div>
                                <div class="text-white-50 small">@r.Details</div>
                            </td>
                            <td>
                                <span class="badge @(r.Status == "Pending" ? "bg-danger" : "bg-success")">
                                    @r.Status
                                </span>
                            </td>
                            <td class="small">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                @if (r.Status == "Pending")
                                {
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-outline-danger dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            Resolve
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-dark bg-dark">
                                            <li>
                                                <form asp-action="ResolveReport" method="post">
                                                    <input type="hidden" name="id" value="@r.ReportId" />
                                                    <input type="hidden" name="takeAction" value="true" />
                                                    <button type="submit" class="dropdown-item px-3 py-2">
                                                        <i class="bi bi-trash me-2 text-danger"></i> Take Action (Delete/Lock)
                                                    </button>
                                                </form>
                                            </li>
                                            <li>
                                                <form asp-action="ResolveReport" method="post">
                                                    <input type="hidden" name="id" value="@r.ReportId" />
                                                    <input type="hidden" name="takeAction" value="false" />
                                                    <button type="submit" class="dropdown-item px-3 py-2">
                                                        <i class="bi bi-check2 me-2 text-success"></i> Fixed Manually
                                                    </button>
                                                </form>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="DismissReport" method="post">
                                                    <input type="hidden" name="id" value="@r.ReportId" />
                                                    <button type="submit" class="dropdown-item px-3 py-2">
                                                        <i class="bi bi-x-lg me-2 text-white-50"></i> Dismiss Report
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                    <button class="btn btn-sm btn-outline-light ms-2" onclick="alert('Details: @r.Details')">View Details</button>
                                }
                                else
                                {
                                    <span class="text-white-50 small">Resolved on @r.ResolvedAt?.ToString("dd/MM/yyyy")</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .bg-dark-glass { background: rgba(30,30,30,0.85); backdrop-filter: blur(10px); }
</style>
